NODE_ENV=development
PORT=3000

# PostgreSQL connection string from Render Postgres or local Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gs_account_manager

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace_with_32_random_bytes_base64
SESSION_SECRET=replace_with_a_long_random_session_secret

APP_NAME=GS Account Manager
COOKIE_SECURE=false
AUTO_MIGRATE=true
AUTH_MODE=discord
APP_BASE_URL=http://localhost:3000

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Optional emergency fallback login. Discord OAuth is the primary login.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
