<%- include('partials/head') %>
<section class="metric-grid dashboard-metrics">
  <article class="metric"><span>Total Accounts</span><strong><%= dashboardStats.total_accounts || 0 %></strong></article>
  <article class="metric"><span>Active Accounts</span><strong><%= dashboardStats.active_accounts || 0 %></strong></article>
  <article class="metric"><span>Locked Accounts</span><strong><%= dashboardStats.locked_accounts || 0 %></strong></article>
  <article class="metric"><span>Invalid Accounts</span><strong><%= dashboardStats.invalid_accounts || 0 %></strong></article>
  <article class="metric"><span>Banned Temp / Perm</span><strong><%= dashboardStats.banned_temp_accounts || 0 %> / <%= dashboardStats.banned_perm_accounts || 0 %></strong></article>
  <article class="metric"><span>Total Proxies</span><strong><%= dashboardStats.total_proxies || 0 %></strong></article>
  <article class="metric"><span>Connected Companions</span><strong><%= dashboardStats.connected_companions || 0 %></strong></article>
  <article class="metric"><span>Running Instances</span><strong><%= dashboardStats.running_instances || 0 %></strong></article>
  <article class="metric"><span>Pending Jobs</span><strong><%= dashboardStats.pending_jobs || 0 %></strong></article>
</section>

<section class="dashboard-hero">
  <form method="get" class="account-picker">
    <label>Current Account
      <select name="account_id">
        <% selectable.forEach(item => { %>
          <option value="<%= item.id %>" <%= selected && selected.id === item.id ? 'selected' : '' %>>
            <%= item.display_name || mask(item.legacy_login || item.username) %> - <%= item.status %>
          </option>
        <% }) %>
      </select>
    </label>
    <button class="button">Load</button>
  </form>
  <% if (selected) { %>
    <div class="current-account">
      <p class="eyebrow"><%= selected.account_type %> workflow</p>
      <h2><%= selected.display_name || mask(selected.legacy_login || selected.username) %></h2>
      <p class="muted"><%= nextStep %></p>
      <div class="actions">
        <span class="status <%= selected.status %>"><%= selected.status %></span>
        <span class="tag"><%= selected.credential_status %> credentials</span>
        <span class="tag"><%= selected.upgrade_status %> upgrade</span>
      </div>
    </div>
  <% } else { %>
    <div class="current-account">
      <h2>Import accounts to begin.</h2>
      <p class="muted">Start with a TXT import, add one account manually, or confirm deployment settings before storing data.</p>
      <div class="actions">
        <a class="button primary" href="/accounts">Import Accounts</a>
        <a class="button" href="/accounts/new">Add Account Manually</a>
        <a class="button" href="/settings">Open Settings</a>
      </div>
    </div>
  <% } %>
</section>

<section class="metric-grid">
  <% const countMap = Object.fromEntries(counts.map(c => [c.status, c.count])); %>
  <% accountStatuses.forEach(status => { %>
    <article class="metric">
      <span><%= status.replace('_', ' ') %></span>
      <strong><%= countMap[status] || 0 %></strong>
    </article>
  <% }) %>
</section>

<section class="step-grid">
  <% ['Import / Add','Assign Proxy','Launch Client','Run Workflow','Review Logs'].forEach((step, index) => { %>
    <article class="panel step">
      <span class="step-num"><%= index + 1 %></span>
      <h2><%= step %></h2>
      <p class="muted"><%= index === 0 ? 'Store accounts and proxies securely.' : 'Everything remains visible, user-triggered, and manual-safe.' %></p>
    </article>
  <% }) %>
</section>

<section class="content-grid">
  <article class="panel">
    <div class="panel-head">
      <h2>Quick Copy</h2>
      <% if (selected) { %><a class="button small" href="/accounts/<%= selected.id %>">Edit account</a><% } %>
    </div>
    <% if (selected) { %>
      <div class="copy-grid">
        <% [
          ['legacy_login','Legacy login'], ['legacy_password','Legacy password'], ['otp_code','OTP code'], ['otp_secret','OTP secret/note'],
          ['target_email','Target email'], ['email_password','Email password'], ['first_name','First name'], ['last_name','Last name'],
          ['birth_date','Birth date'], ['birth_month','Birth month'], ['birth_day','Birth day'], ['birth_year','Birth year'],
          ['jagex_email','Jagex email'], ['jagex_password','Jagex password'], ['jagex_name','Jagex name']
        ].forEach(item => { %>
          <button class="button small copy-api" data-url="/accounts/<%= selected.id %>/copy/<%= item[0] %>"><%= item[1] %></button>
        <% }) %>
      </div>
    <% } else { %>
      <p class="muted">Select an account to enable copy buttons.</p>
    <% } %>
  </article>

  <article class="panel">
    <div class="panel-head">
      <div>
        <h2><%= helper.connected ? 'Open with Companion' : 'Open in this browser' %></h2>
        <p class="muted"><%= helper.connected ? 'Uses assigned proxy if selected.' : 'No proxy control from website.' %></p>
      </div>
      <a class="button small" href="/companion">Companion</a>
    </div>
    <% if (!helper.connected && settings.warn_before_opening_without_helper === 'true') { %>
      <p class="notice">To use Chrome with proxies, install and connect GS Account Manager Companion. Website-only opens use your normal browser session.</p>
    <% } %>
    <% if (selected && settings.show_proxy_mode_before_open !== 'false') { %>
      <div class="proxy-mode-grid">
        <p class="row-line"><span>Browser mode</span><strong><%= proxyMode.browserMode %></strong></p>
        <p class="row-line"><span>Helper connected</span><strong><%= proxyMode.helperConnected %></strong></p>
        <p class="row-line"><span>Selected proxy type</span><strong><%= proxyMode.proxyType %></strong></p>
        <p class="row-line"><span>Selected proxy</span><strong><%= proxyMode.proxyEndpoint %></strong></p>
        <p class="row-line"><span>Direct fallback</span><strong><%= proxyMode.directFallback %></strong></p>
      </div>
      <p class="muted"><%= proxyMode.modeDescription %></p>
    <% } %>
    <div class="copy-grid">
      <a class="button" target="_blank" rel="noopener" href="<%= settings.email_signup_url || 'https://signup.live.com/' %>">Open email signup page</a>
      <a class="button" target="_blank" rel="noopener" href="<%= settings.email_signin_url || 'https://outlook.live.com/' %>">Open email sign-in page</a>
      <a class="button" target="_blank" rel="noopener" href="<%= settings.account_settings_url || 'https://account.jagex.com/' %>">Open account settings page</a>
      <a class="button" target="_blank" rel="noopener" href="<%= settings.upgrade_url || 'https://account.jagex.com/' %>">Open upgrade page</a>
    </div>
    <p class="muted">Buttons only open pages. The app never types, submits, creates accounts, or bypasses checks.</p>
    <% if (selected) { %>
      <div class="assist-panel">
        <p class="eyebrow">Assisted Actions</p>
        <div class="actions">
          <button class="button small" type="button" disabled>Helper Required</button>
          <button class="button small" type="button" disabled>Fill Visible Fields</button>
          <span class="tag">Requires your click</span>
          <span class="tag">You stay in control</span>
        </div>
      </div>
    <% } %>
  </article>
</section>

<section class="panel">
  <div class="panel-head">
    <h2>Recent Safe Activity</h2>
    <a class="button small" href="/logs">View logs</a>
  </div>
  <table>
    <thead><tr><th>Time</th><th>Action</th><th>Message</th></tr></thead>
    <tbody>
      <% recent.forEach(log => { %>
        <tr><td><%= new Date(log.created_at).toLocaleString() %></td><td><%= log.action %></td><td><%= log.message || '' %></td></tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('partials/foot') %>
