<%- include('partials/head') %>
<section class="helper-hero">
  <article class="panel download-card">
    <p class="eyebrow">Windows Companion</p>
    <h2><%= companionName %></h2>
    <div class="helper-detail-grid">
      <p class="row-line"><span>Status</span><strong>Coming soon</strong></p>
      <p class="row-line"><span>Latest version</span><strong><%= download.version %></strong></p>
      <p class="row-line"><span>Release date</span><strong><%= download.releaseDate %></strong></p>
      <p class="row-line"><span>Future artifact</span><strong>GSWorkFlowManager.exe</strong></p>
    </div>
    <div class="actions">
      <a class="button primary" href="<%= download.windowsPath %>">Download for Windows</a>
      <span class="tag">Placeholder</span>
    </div>
    <p class="notice">Only download companion builds from GS Account Manager. The companion never bypasses CAPTCHA, MFA, security checks, or website anti-abuse systems.</p>
  </article>

  <article class="panel">
    <p class="eyebrow">Pairing</p>
    <h2>Setup Instructions</h2>
    <ol class="helper-list">
      <li>Log in with Discord on the website.</li>
      <li>Open Companion and generate a pairing code.</li>
      <li>Enter the code in the Windows companion app.</li>
      <li>Use controlled browser actions only after a clear user click.</li>
    </ol>
    <a class="button" href="/companion">Open Companion Page</a>
  </article>
</section>
<%- include('partials/foot') %>
