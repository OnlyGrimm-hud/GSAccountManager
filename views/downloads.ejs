<%- include('partials/head') %>
<section class="helper-hero">
  <article class="panel download-card">
    <p class="eyebrow">Windows Companion App</p>
    <h2><%= companionName %></h2>
    <div class="helper-detail-grid">
      <p class="row-line"><span>Status</span><strong><%= download.available ? 'Available' : 'Coming soon' %></strong></p>
      <p class="row-line"><span>Version</span><strong><%= download.version %></strong></p>
      <p class="row-line"><span>Release</span><strong><%= download.releaseDate %></strong></p>
      <p class="row-line"><span>File size</span><strong><%= download.fileSize || 'Not packaged yet' %></strong></p>
    </div>
    <div class="actions">
      <% if (download.available) { %>
        <a class="button primary" href="<%= download.windowsPath %>">Download for Windows</a>
      <% } else { %>
        <button class="button primary" type="button" disabled>Coming soon</button>
      <% } %>
      <a class="button" href="/companion">Open Companion</a>
    </div>
    <p class="notice">Security note: the companion only connects to your own GS Account Manager account after pairing. Pairing codes expire quickly, and device tokens are stored server-side only as hashes.</p>
  </article>

  <article class="panel">
    <p class="eyebrow">Install Instructions</p>
    <h2>Before First Use</h2>
    <ol class="helper-list">
      <li>Log in to GS Account Manager with Discord.</li>
      <li>Open Companion and create a pairing code.</li>
      <li>Install the Windows companion when the package is released.</li>
      <li>Enter the pairing code in the local app.</li>
      <li>Confirm the website shows the device as connected.</li>
    </ol>
    <p class="muted">The companion foundation currently supports pairing and heartbeat placeholders. Controlled browser fill remains planned and user-triggered only.</p>
  </article>
</section>
<%- include('partials/foot') %>
