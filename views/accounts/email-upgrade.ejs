<%- include('../partials/head') %>
<%
  const loginValue = account.legacy_login || account.username || decrypted.login_email || '';
  const targetEmail = decrypted.target_email || decrypted.jagex_email || '';
  const currentEmail = decrypted.jagex_email || decrypted.target_email || account.username || '';
  const selectedProxyId = accountProxyId ? String(accountProxyId) : '';
  const selectedProxy = proxies.find(proxy => String(proxy.id) === selectedProxyId);
  const connectedDevices = (browserAgent && browserAgent.connectedDevices) || devices.filter(device => device.status === 'connected');
  const browserAgentReady = Boolean(browserAgent && browserAgent.connected);
  const passwordReady = Boolean(decrypted.legacy_password || decrypted.login_password || decrypted.jagex_password);
  const maskHost = value => {
    const text = String(value || '');
    if (!text) return '';
    return text.length <= 8 ? text : `${text.slice(0, 3)}...${text.slice(-3)}`;
  };
  const readiness = [
    { label: 'Current login/email', ready: Boolean(loginValue), text: loginValue || 'Missing login/email' },
    { label: 'Account password', ready: passwordReady, text: passwordReady ? 'Saved and encrypted' : 'Missing password' },
    { label: 'Target/Jagex email', ready: Boolean(targetEmail), text: targetEmail || 'Add target email below' },
    { label: 'GS Browser Agent', ready: browserAgentReady, text: connectedDevices.length ? `${connectedDevices.length} connected` : 'Connect GS Browser Agent first' },
    { label: 'Browser Automator access', ready: Boolean(access && access.gates && access.gates.browserAutomator && access.gates.runBrowserTask), text: access && access.gates && access.gates.runBrowserTask ? 'Ready' : 'Upgrade or daily limit required' },
    { label: 'OTP status', ready: true, text: decrypted.otp_secret ? 'OTP secret saved - fill requires confirmation' : 'No OTP secret saved' }
  ];
  const canQueue = readiness.every(item => item.ready);
  const canSubmit = readiness.filter(item => item.label !== 'Target/Jagex email').every(item => item.ready);
%>

<section class="workflow-hero">
  <div>
    <p class="eyebrow">One-click account action</p>
    <h2>Email Upgrade</h2>
    <p class="muted">Queue a Browser Agent job for this account. GS Browser Agent opens the visible browser locally on your PC.</p>
  </div>
  <div class="actions">
    <span class="status <%= canQueue ? 'ready' : 'needs_review' %>"><%= canQueue ? 'Ready' : 'Missing Info' %></span>
    <a class="button small" href="/accounts">Cancel</a>
  </div>
</section>

<section class="content-grid email-upgrade-grid">
  <article class="panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Selected Account</p>
        <h2><%= account.display_name || loginValue || `Account ${account.id}` %></h2>
      </div>
      <a class="button small" href="/accounts/<%= account.id %>">Edit Account</a>
    </div>
    <div class="checklist-grid">
      <p class="row-line"><span>Current login</span><strong class="full-value"><%= loginValue || 'Not saved' %></strong></p>
      <p class="row-line"><span>Email/Jagex email</span><strong class="full-value"><%= currentEmail || 'Not saved' %></strong></p>
      <p class="row-line"><span>Target email</span><strong class="full-value"><%= targetEmail || 'Missing' %></strong></p>
      <p class="row-line"><span>Account type</span><strong><%= account.account_type || 'legacy' %></strong></p>
      <p class="row-line"><span>Status</span><strong><%= account.status || 'available' %></strong></p>
      <p class="row-line"><span>Assigned proxy</span><strong><%= selectedProxy ? `${selectedProxy.name || 'Proxy'} - ${maskHost(selectedProxy.host)}:${selectedProxy.port}` : 'Account/default or direct' %></strong></p>
      <p class="row-line"><span>Proxy type/status</span><strong><%= selectedProxy ? `${selectedProxy.proxy_type || 'HTTP'} / ${selectedProxy.status || 'unknown'}` : 'No selected proxy' %></strong></p>
      <p class="row-line"><span>OTP</span><strong><%= decrypted.otp_secret ? 'Available, confirmation required' : 'Not saved' %></strong></p>
    </div>
    <% if (decrypted.otp_secret) { %>
      <div class="actions">
        <button class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/otp_code">Copy OTP Code</button>
      </div>
    <% } %>
    <div class="notice">
      <strong>Owned Webmail Verification - Coming Later</strong>
      <p class="muted">This pass does not add webmail pools, email generation, or email verification automation. Email verification remains a manual step in the visible browser.</p>
    </div>
  </article>

  <article class="panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Readiness</p>
        <h2>Preflight Checklist</h2>
      </div>
      <span class="status <%= browserAgentReady ? 'connected' : 'unknown' %>"><%= browserAgent && browserAgent.statusLabel ? browserAgent.statusLabel : 'Not Connected' %></span>
    </div>
    <div class="checklist-grid">
      <p class="row-line"><span>Device name</span><strong><%= browserAgent && browserAgent.deviceName ? browserAgent.deviceName : 'No connected Browser Agent' %></strong></p>
      <p class="row-line"><span>Version</span><strong><%= browserAgent && browserAgent.version ? browserAgent.version : 'Not available' %></strong></p>
      <p class="row-line"><span>Last seen</span><strong><%= browserAgent && browserAgent.lastSeenAt ? new Date(browserAgent.lastSeenAt).toLocaleString() : 'Not connected' %></strong></p>
    </div>
    <div class="checklist-grid">
      <% readiness.forEach(item => { %>
        <p class="row-line"><span><%= item.label %></span><strong><span class="status <%= item.ready ? 'ready' : 'failed' %>"><%= item.ready ? 'Ready' : 'Missing' %></span> <span class="muted"><%= item.text %></span></strong></p>
      <% }) %>
    </div>
    <% if (!canSubmit) { %>
      <p class="notice danger">Fix the missing checklist items before queuing this action. GS will not silently start a broken browser job.</p>
    <% } else if (!targetEmail) { %>
      <p class="notice">Add the target/Jagex email in the start form, then queue the job. The server validates it again before creating the local job.</p>
    <% } else if (!browserAgentReady) { %>
      <p class="notice">Connect GS Browser Agent first. Browser automation cannot queue until a paired Browser Agent is currently connected.</p>
    <% } else { %>
      <p class="notice">GS Browser Agent is connected. Queue the job, then use the agent to fetch and run it visibly.</p>
    <% } %>
  </article>
</section>

<section class="content-grid email-upgrade-grid">
  <article class="panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Queue Browser Agent Job</p>
        <h2>Start Email Upgrade</h2>
      </div>
      <span class="status queued">Browser Agent job</span>
    </div>
    <form method="post" action="/accounts/<%= account.id %>/email-upgrade" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Target/Jagex Email
        <input name="target_email" value="<%= targetEmail %>" placeholder="new-email@example.com" required>
      </label>
      <label>Connected Browser Agent
        <select name="companion_device_id">
          <option value="">Any connected Browser Agent</option>
          <% devices.forEach(device => { %>
            <% const optionIsConnected = device.status === 'connected' && device.device_role !== 'agent'; %>
            <option value="<%= device.id %>" <%= optionIsConnected ? '' : 'disabled' %>><%= device.device_name || `Device ${device.id}` %> - <%= device.status || 'unknown' %><%= device.companion_version ? ` - v${device.companion_version}` : '' %><%= device.last_seen_at ? ` - ${new Date(device.last_seen_at).toLocaleString()}` : '' %></option>
          <% }) %>
        </select>
      </label>
      <label>Proxy
        <select name="proxy_id">
          <option value="">Use account/default proxy or direct</option>
          <% proxies.forEach(proxy => { %>
            <option value="<%= proxy.id %>" <%= String(proxy.id) === selectedProxyId ? 'selected' : '' %>><%= proxy.name || `${proxy.host}:${proxy.port}` %> - <%= proxy.proxy_type || 'HTTP' %> - <%= proxy.status || 'unknown' %></option>
          <% }) %>
        </select>
      </label>
      <label class="check">
        <input type="checkbox" name="include_otp" value="yes" <%= decrypted.otp_secret ? 'checked' : '' %>>
        Include optional OTP fill step. GS Browser Agent asks before filling the generated code.
      </label>
      <div class="notice">
        <strong>Manual checks pause the job</strong>
        <p class="muted">CAPTCHA, Cloudflare, 2FA prompts, email verification, phone verification, and security checks are never bypassed. Complete them in the visible browser, then click Continue in GS Browser Agent to resume.</p>
      </div>
      <div class="actions">
        <button class="button primary" <%= canSubmit ? '' : 'disabled' %>>Queue Browser Agent Job</button>
        <a class="button" href="/accounts/<%= account.id %>">Edit Account</a>
        <a class="button" href="/proxies">Change Proxy</a>
        <% if (!browserAgentReady) { %>
          <a class="button" href="/downloads">Download Browser Agent</a>
          <a class="button" href="/companion">Connect Browser Agent</a>
        <% } else { %>
          <a class="button" href="/companion">Change Browser Agent</a>
        <% } %>
      </div>
    </form>
  </article>

  <article class="panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Estimated Flow</p>
        <h2>What GS Browser Agent Will Do</h2>
      </div>
      <span class="tag">User-triggered</span>
    </div>
    <div class="setup-timeline">
      <% [
        ['1', 'Open visible browser', 'GS Browser Agent launches Playwright locally.'],
        ['2', 'Apply proxy if selected', selectedProxy ? 'Saved proxy credentials are requested by the paired device only.' : 'Runs direct unless you select or assign a proxy.'],
        ['3', 'Fill current login/password', 'Values are pulled from your encrypted account record and are not logged.'],
        ['4', 'Pause for manual checks', 'CAPTCHA, Cloudflare, security, email, phone, and 2FA checks stay manual.'],
        ['5', 'Optional OTP fill', 'If saved, GS Browser Agent asks before filling the generated OTP code.'],
        ['6', 'Fill target email', 'GS fills the target/Jagex email and pauses for your final review.']
      ].forEach(step => { %>
        <article>
          <div class="step-num"><%= step[0] %></div>
          <h2><%= step[1] %></h2>
          <p class="muted"><%= step[2] %></p>
        </article>
      <% }) %>
    </div>
  </article>
</section>

<%- include('../partials/foot') %>
