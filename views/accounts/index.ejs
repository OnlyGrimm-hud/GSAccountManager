<%- include('../partials/head') %>
<% const stat = stats || {}; %>
<% const noticeImported = query && query.imported ? Number(query.imported || 0) : null; %>
<section class="metric-grid account-metrics">
  <% [
    ['Total Accounts', stat.total || 0],
    ['Active Accounts', stat.active || 0],
    ['Banned Accounts', stat.banned || 0],
    ['Locked Accounts', stat.locked || 0],
    ['Invalid Accounts', stat.invalid || 0]
  ].forEach(item => { %>
    <article class="metric"><span><%= item[0] %></span><strong><%= item[1] %></strong></article>
  <% }) %>
</section>

<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Storage</p>
      <h2>Accounts</h2>
    </div>
    <div class="actions">
      <% if (!isLimitedAccess) { %>
        <button class="button" type="button" data-open-modal="account-import-modal">Import Accounts</button>
        <a class="button" href="/accounts/new">Add Account Manually</a>
      <% } %>
      <button class="button primary" type="button" data-open-modal="account-export-modal">Export Selected</button>
    </div>
  </div>
  <% if (noticeImported !== null) { %>
    <p class="notice">Imported <%= noticeImported %> account line(s). Skipped <%= Number(query.skipped || 0) %>.</p>
  <% } %>
  <% if (query && query.import_export_moved) { %>
    <p class="notice">Account import and export now live here on the Accounts page.</p>
  <% } %>
  <% if (query && query.stats_sync) { %>
    <p class="notice">Stats sync <%= query.stats_sync %><%= query.stats_error ? `: ${query.stats_error}` : '' %>.</p>
  <% } %>
  <p class="notice">Account details are owner-only. Full usernames display directly; passwords, OTP secrets, recovery credentials, and email passwords stay encrypted until you click Reveal or Copy.</p>
  <div class="agent-status-card">
    <div>
      <p class="eyebrow">Connected Browser Agent</p>
      <h2><%= browserAgent.statusLabel %></h2>
      <p class="muted">Browser automation is queued here and executed only by GS Browser Agent on your Windows PC.</p>
    </div>
    <div class="checklist-grid">
      <p class="row-line"><span>Status</span><strong><span class="status <%= browserAgent.connected ? 'connected' : 'unknown' %>"><%= browserAgent.statusLabel %></span></strong></p>
      <p class="row-line"><span>Device</span><strong><%= browserAgent.deviceName %></strong></p>
      <p class="row-line"><span>Version</span><strong><%= browserAgent.version %></strong></p>
      <p class="row-line"><span>Last Seen</span><strong><%= browserAgent.lastSeenAt ? new Date(browserAgent.lastSeenAt).toLocaleString() : 'Not connected' %></strong></p>
    </div>
    <% if (!browserAgent.connected) { %>
      <div class="actions">
        <a class="button small" href="/downloads">Download Browser Agent</a>
        <a class="button small" href="/companion">Connect Browser Agent</a>
      </div>
    <% } %>
  </div>

  <form class="filters account-filters" method="get">
    <input name="q" placeholder="Search" value="<%= filters.q || '' %>">
    <select name="country_code"><option value="">Country</option><% countries.forEach(country => { %><option value="<%= country %>" <%= filters.country_code === country ? 'selected' : '' %>><%= country %></option><% }) %></select>
    <select name="account_type"><option value="">Account Type</option><% accountTypes.forEach(t => { %><option value="<%= t %>" <%= filters.account_type === t ? 'selected' : '' %>><%= t %></option><% }) %></select>
    <select name="character_type"><option value="">Character Type / Category</option><% categories.forEach(category => { %><option value="<%= category %>" <%= filters.character_type === category || filters.category === category ? 'selected' : '' %>><%= category %></option><% }) %></select>
    <select name="status"><option value="">Status</option><% accountStatuses.forEach(s => { %><option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option><% }) %></select>
    <select name="has_notes"><option value="">Has Notes</option><option value="yes" <%= filters.has_notes === 'yes' ? 'selected' : '' %>>Yes</option><option value="no" <%= filters.has_notes === 'no' ? 'selected' : '' %>>No</option></select>
    <select name="has_proxy"><option value="">Has Proxy</option><option value="yes" <%= filters.has_proxy === 'yes' ? 'selected' : '' %>>Yes</option><option value="no" <%= filters.has_proxy === 'no' ? 'selected' : '' %>>No</option></select>
    <select name="completed_tutorial"><option value="">Has Completed Tutorial</option><option value="yes" <%= filters.completed_tutorial === 'yes' ? 'selected' : '' %>>Yes</option><option value="no" <%= filters.completed_tutorial === 'no' ? 'selected' : '' %>>No</option></select>
    <select name="has_active_instance"><option value="">Has Active Instance</option><option value="yes" <%= filters.has_active_instance === 'yes' ? 'selected' : '' %>>Yes</option><option value="no" <%= filters.has_active_instance === 'no' ? 'selected' : '' %>>No</option></select>
    <select name="verified"><option value="">Verified</option><option value="yes" <%= filters.verified === 'yes' ? 'selected' : '' %>>Yes</option><option value="no" <%= filters.verified === 'no' ? 'selected' : '' %>>No</option><option value="unknown" <%= filters.verified === 'unknown' ? 'selected' : '' %>>Unknown</option></select>
    <select name="authenticator"><option value="">Authenticator</option><option value="yes" <%= filters.authenticator === 'yes' || filters.has_otp === 'yes' ? 'selected' : '' %>>Yes</option><option value="no" <%= filters.authenticator === 'no' || filters.has_otp === 'no' ? 'selected' : '' %>>No</option></select>
    <select name="bans"><option value="">Bans</option><option value="none" <%= filters.bans === 'none' ? 'selected' : '' %>>None</option><option value="any" <%= filters.bans === 'any' ? 'selected' : '' %>>Any</option><option value="temp" <%= filters.bans === 'temp' ? 'selected' : '' %>>Temp</option><option value="perm" <%= filters.bans === 'perm' ? 'selected' : '' %>>Perm</option></select>
    <select name="archived"><option value="">Archived</option><option value="no" <%= filters.archived === 'no' ? 'selected' : '' %>>Active list</option><option value="yes" <%= filters.archived === 'yes' ? 'selected' : '' %>>Archived</option></select>
    <input name="min_total_level" type="number" min="0" placeholder="Min Total Level" value="<%= filters.min_total_level || '' %>">
    <input name="max_total_level" type="number" min="0" placeholder="Max Total Level" value="<%= filters.max_total_level || '' %>">
    <select name="sort_by">
      <option value="updated_desc" <%= filters.sort_by === 'updated_desc' ? 'selected' : '' %>>Sort: Updated</option>
      <option value="created_desc" <%= filters.sort_by === 'created_desc' ? 'selected' : '' %>>Created</option>
      <option value="username_asc" <%= filters.sort_by === 'username_asc' ? 'selected' : '' %>>Username</option>
      <option value="wealth_desc" <%= filters.sort_by === 'wealth_desc' ? 'selected' : '' %>>Wealth</option>
      <option value="gp_desc" <%= filters.sort_by === 'gp_desc' ? 'selected' : '' %>>GP</option>
      <option value="total_level_desc" <%= filters.sort_by === 'total_level_desc' ? 'selected' : '' %>>Total Level</option>
      <option value="status_asc" <%= filters.sort_by === 'status_asc' ? 'selected' : '' %>>Status</option>
    </select>
    <select name="created_date">
      <option value="">Created Date</option>
      <option value="today" <%= filters.created_date === 'today' ? 'selected' : '' %>>Today</option>
      <option value="7d" <%= filters.created_date === '7d' ? 'selected' : '' %>>Last 7 days</option>
      <option value="30d" <%= filters.created_date === '30d' ? 'selected' : '' %>>Last 30 days</option>
      <option value="older_30d" <%= filters.created_date === 'older_30d' ? 'selected' : '' %>>Older than 30 days</option>
    </select>
    <button class="button">Filter</button>
  </form>

  <form id="account-action-form" method="post" action="/accounts/export">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% ['q','account_type','category','character_type','status','has_proxy','has_otp','has_notes','completed_tutorial','has_active_instance','verified','authenticator','bans','archived','country_code','min_total_level','max_total_level','sort_by','created_date'].forEach(key => { %>
      <input type="hidden" name="<%= key %>" value="<%= filters[key] || '' %>">
    <% }) %>
  </form>
  <% if (isLimitedAccess) { %>
    <p class="notice">Private-build access is inactive. Account data remains locked until an admin activates access.</p>
  <% } else { %>
    <div class="bulk-bar">
      <select form="account-action-form" name="bulk_action">
        <option value="launch_selected">Launch selected</option>
        <option value="archive">Archive selected</option>
        <option value="delete">Delete selected</option>
        <option value="assign_proxy">Assign proxy</option>
        <option value="assign_category_status">Assign category/status</option>
      </select>
      <select form="account-action-form" name="bulk_client_profile_id">
        <option value="">Launch profile</option>
        <% clientProfiles.forEach(profile => { %><option value="<%= profile.id %>"><%= profile.name %></option><% }) %>
      </select>
      <select form="account-action-form" name="proxy_id">
        <option value="">No proxy / unchanged</option>
        <% proxies.forEach(proxy => { %><option value="<%= proxy.id %>"><%= proxy.name || `${proxy.host}:${proxy.port}` %> - <%= proxy.proxy_type %></option><% }) %>
      </select>
      <input form="account-action-form" name="bulk_category" placeholder="Category">
      <select form="account-action-form" name="bulk_status"><% accountStatuses.forEach(status => { %><option value="<%= status %>"><%= status %></option><% }) %></select>
      <label class="check"><input form="account-action-form" type="checkbox" name="confirm_bulk_delete" value="yes"> Confirm permanent bulk delete</label>
      <button class="button" form="account-action-form" formaction="/accounts/bulk">Apply bulk action</button>
      <% if (!(isAdmin || (access && access.tier && access.tier.client_launcher_enabled))) { %><span class="tag">Client launcher requires a higher tier</span><% } %>
      <span class="tag">Future: register / upgrade automations</span>
      <span class="tag">Browser Automator available under My Workspace</span>
    </div>
  <% } %>
  <table>
    <thead>
      <tr>
        <th><input type="checkbox" data-select-all="[name='account_ids']"></th>
        <th>Proxy</th>
        <th>Username / Login</th>
        <th>Verified</th>
        <th>Display Name</th>
        <th>Client Status</th>
        <th>Total Level</th>
        <th>Combat Level</th>
        <th>GP / Wealth</th>
        <th>Last Seen</th>
        <th>Notes</th>
        <th>Bans</th>
        <th>Status</th>
        <th>Running Session</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% accounts.forEach(account => { %>
        <% const rowClientState = clientStateFromRow(account); %>
        <tr>
          <td><input form="account-action-form" type="checkbox" name="account_ids" value="<%= account.id %>"></td>
          <td>
            <% if (account.proxy_host) { %>
              <strong><%= account.proxy_type || 'HTTP' %></strong><br>
              <span class="status <%= account.proxy_status || 'unknown' %>"><%= account.proxy_status || 'assigned' %></span>
            <% } else { %>
              <span class="tag">No proxy</span>
            <% } %>
          </td>
          <td>
            <strong class="full-value"><%= account.legacy_login || account.username || 'No login saved' %></strong>
            <br><span class="tag"><%= account.account_type %></span>
            <% if (account.account_type === 'jagex') { %><br><span class="muted">email login</span><% } %>
          </td>
          <td><span class="status <%= account.verified || 'unknown' %>"><%= account.verified || 'unknown' %></span></td>
          <td><%= account.display_name || '' %></td>
          <td>
            <span class="status <%= clientStateClass(rowClientState) %>"><%= clientStateLabel(rowClientState) %></span>
            <% if (account.active_instance_activity) { %><br><span class="muted"><%= account.active_instance_activity %></span><% } %>
          </td>
          <td><%= account.stats_total_level || account.total_level || '-' %></td>
          <td><%= account.stats_combat_level || account.combat_level || '-' %></td>
          <td>
            <strong>GP:</strong> <%= formatWealthValue(account.gp_amount, account.wealth_source) %><br>
            <strong>Bank:</strong> <%= formatWealthValue(account.bank_value, account.wealth_source) %><br>
            <strong>Wealth:</strong> <%= formatWealthValue(account.wealth_value ?? account.wealth_amount, account.wealth_source) %>
            <% if (account.wealth_source && account.wealth_source !== 'unknown') { %><br><span class="tag"><%= account.wealth_source.replace(/_/g, ' ') %></span><% } %>
          </td>
          <td>
            <% if (account.active_instance_last_seen_at || account.client_last_seen_at) { %>
              <%= new Date(account.active_instance_last_seen_at || account.client_last_seen_at).toLocaleString() %>
            <% } else { %>
              <span class="tag">Unknown</span>
            <% } %>
          </td>
          <td><span class="full-value"><%= account.notes || '' %></span></td>
          <td>
            <% if (account.status === 'banned_temp' || account.ban_status === 'temp') { %><span class="status banned_temp">Temp</span>
            <% } else if (account.status === 'banned_perm' || account.ban_status === 'perm') { %><span class="status banned_perm">Perm</span>
            <% } else { %><span class="tag">None</span><% } %>
          </td>
          <td><span class="status <%= account.status %>"><%= account.status %></span></td>
          <td>
            <% if (account.active_instance_id) { %>
              <a class="status <%= clientStateClass(rowClientState) %>" href="/instances/<%= account.active_instance_id %>"><%= clientStateLabel(rowClientState) %></a>
              <% if (account.active_instance_window) { %><br><span class="muted full-value"><%= account.active_instance_window %></span><% } %>
            <% } else { %>
              <span class="tag">None</span>
            <% } %>
          </td>
          <td class="actions">
            <% if (isLimitedAccess) { %>
              <span class="tag">Export only</span>
            <% } else { %>
              <a class="button small" href="/accounts/<%= account.id %>">View</a>
              <a class="button small primary" href="/accounts/<%= account.id %>/email-upgrade">Queue Browser Agent Job</a>
              <details class="action-menu">
                <summary>More actions</summary>
                <div class="action-menu-panel">
                  <a class="button small" href="/accounts/<%= account.id %>">Edit</a>
                  <button class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/legacy_login">Copy login</button>
                  <button class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/legacy_password">Copy pass</button>
                  <% if (account.otp_secret_encrypted) { %><button class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/otp_code">Copy OTP</button><% } %>
                  <form method="post" action="/accounts/<%= account.id %>/refresh-stats">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="button small">Refresh Stats</button>
                  </form>
                  <a class="button small" href="/workflows?account_id=<%= account.id %>">Open Browser Automator</a>
                  <form method="post" action="/accounts/bulk">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="bulk_action" value="launch_selected">
                    <input type="hidden" name="account_ids" value="<%= account.id %>">
                    <input type="hidden" name="bulk_client_profile_id" value="<%= clientProfiles[0] ? clientProfiles[0].id : '' %>">
                    <button class="button small" <%= clientProfiles.length && (isAdmin || (access && access.tier && access.tier.client_launcher_enabled)) ? '' : 'disabled' %>>Launch Client</button>
                  </form>
                  <form method="post" action="/accounts/<%= account.id %>/archive">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="button small">Archive</button>
                  </form>
                  <form method="post" action="/accounts/<%= account.id %>/delete" data-confirm="Delete this local account record?">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="button small danger">Delete</button>
                  </form>
                </div>
              </details>
            <% } %>
          </td>
        </tr>
        <tr class="detail-row account-detail-row">
          <td></td>
          <td colspan="14">
            <div class="account-detail-panel">
              <div class="account-detail-head">
                <div>
                  <p class="eyebrow">Owner Account Details</p>
                  <h2><%= account.display_name || account.legacy_login || account.username || `Account ${account.id}` %></h2>
                </div>
                <a class="button small" href="/accounts/<%= account.id %>">Open Full Record</a>
              </div>
              <div class="credential-detail-grid">
                <p class="row-line"><span>Account ID</span><strong><%= account.id %></strong></p>
                <p class="row-line"><span>Login / Username</span><strong class="full-value"><%= account.legacy_login || account.username || 'Not saved' %></strong></p>
                <p class="row-line"><span>Display Name</span><strong class="full-value"><%= account.display_name || 'Not saved' %></strong></p>
                <p class="row-line"><span>Type / Category</span><strong><%= account.account_type %><%= account.category ? ` / ${account.category}` : '' %></strong></p>
                <p class="row-line"><span>Status</span><strong><%= account.status %></strong></p>
                <p class="row-line"><span>Country</span><strong><%= account.country_code || 'Not set' %></strong></p>

                <div class="secret-line">
                  <span>Login Password</span>
                  <code id="account-<%= account.id %>-legacy-password" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/legacy_password" data-target="#account-<%= account.id %>-legacy-password">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/legacy_password">Copy</button>
                </div>
                <div class="secret-line">
                  <span>Email / Jagex Email</span>
                  <code id="account-<%= account.id %>-jagex-email" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/jagex_email" data-target="#account-<%= account.id %>-jagex-email">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/jagex_email">Copy</button>
                </div>
                <div class="secret-line">
                  <span>Target Email</span>
                  <code id="account-<%= account.id %>-target-email" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/target_email" data-target="#account-<%= account.id %>-target-email">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/target_email">Copy</button>
                </div>
                <div class="secret-line">
                  <span>Email Password</span>
                  <code id="account-<%= account.id %>-email-password" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/email_password" data-target="#account-<%= account.id %>-email-password">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/email_password">Copy</button>
                </div>
                <div class="secret-line">
                  <span>Jagex Password</span>
                  <code id="account-<%= account.id %>-jagex-password" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/jagex_password" data-target="#account-<%= account.id %>-jagex-password">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/jagex_password">Copy</button>
                </div>
                <div class="secret-line">
                  <span>Recovery Email</span>
                  <code id="account-<%= account.id %>-recovery-email" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/recovery_email" data-target="#account-<%= account.id %>-recovery-email">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/recovery_email">Copy</button>
                </div>
                <div class="secret-line">
                  <span>Recovery Email Password</span>
                  <code id="account-<%= account.id %>-recovery-email-password" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/recovery_email_password" data-target="#account-<%= account.id %>-recovery-email-password">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/recovery_email_password">Copy</button>
                </div>
                <div class="secret-line">
                  <span>Bank PIN</span>
                  <code id="account-<%= account.id %>-bank-pin" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/bank_pin" data-target="#account-<%= account.id %>-bank-pin">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/bank_pin">Copy</button>
                </div>
                <div class="secret-line">
                  <span>OTP Secret</span>
                  <code id="account-<%= account.id %>-otp-secret" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/otp_secret" data-target="#account-<%= account.id %>-otp-secret">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/otp_secret">Copy</button>
                </div>
                <div class="secret-line">
                  <span>OTP Code</span>
                  <code id="account-<%= account.id %>-otp-code" class="secret-value">Hidden until Reveal</code>
                  <button type="button" class="button small reveal-api" data-url="/accounts/<%= account.id %>/reveal/otp_code" data-target="#account-<%= account.id %>-otp-code">Reveal</button>
                  <button type="button" class="button small copy-api" data-url="/accounts/<%= account.id %>/copy/otp_code">Copy</button>
                </div>
                <p class="row-line wide"><span>Notes</span><strong class="full-value"><%= account.notes || 'No notes' %></strong></p>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (!accounts.length) { %>
        <tr><td colspan="15"><p class="muted">Import accounts to begin.</p></td></tr>
      <% } %>
    </tbody>
  </table>
</section>

<% if (!isLimitedAccess) { %>
<div class="modal" id="account-import-modal" hidden>
  <div class="modal-panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Import</p>
        <h2>Import Accounts</h2>
      </div>
      <button class="icon-button" type="button" data-close-modal>Close</button>
    </div>
    <form id="account-import-form" method="post" action="/accounts/import" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="confirm_import" value="">
      <div class="form-grid three">
        <label>Account Type<select name="account_type" data-account-import-type><option value="legacy">Legacy</option><option value="jagex">Jagex</option></select></label>
        <label>Import Format<select name="import_format">
          <option value="">Auto detect</option>
          <option value="legacy_basic">username:password</option>
          <option value="legacy_pin">username:password:bank_pin</option>
          <option value="legacy_pin_otp">username:password:bank_pin:otp_secret</option>
          <option value="legacy_recovery">username:password:recovery_email:recovery_password</option>
          <option value="legacy_target_email">username:password:target_email:email_password:first_name:last_name:birth_date</option>
          <option value="jagex_legacy">jagex_email:jagex_password:legacy_login:legacy_password:otp_secret</option>
        </select></label>
        <label>Account Category<input list="account-category-options" name="category" placeholder="main"></label>
        <label>Proxy Category<input list="proxy-category-options" name="proxy_category" placeholder="optional"></label>
        <label>Country Code<input list="country-options" name="country_code" maxlength="2" placeholder="US"></label>
        <label>Delimiter<input name="delimiter" value=":" maxlength="4" data-account-import-delimiter></label>
        <label>Notes<input name="notes" placeholder="batch note"></label>
      </div>
      <datalist id="account-category-options"><% categories.forEach(category => { %><option value="<%= category %>"></option><% }) %></datalist>
      <datalist id="proxy-category-options"><% proxyCategories.forEach(category => { %><option value="<%= category %>"></option><% }) %></datalist>
      <datalist id="country-options"><% countries.forEach(country => { %><option value="<%= country %>"></option><% }) %></datalist>
      <div class="notice">
        <strong>Format examples</strong>
        <p class="muted">Legacy: username:password | username:password:bank_pin | username:password:bank_pin:otp_secret</p>
        <p class="muted">Legacy recovery: username:password:recovery_email:recovery_password</p>
        <p class="muted">Target email: username:password:target_email:email_password:first_name:last_name:birth_date</p>
        <p class="muted">Jagex: email:password | jagex_email:jagex_password:legacy_login:legacy_password:otp_secret</p>
      </div>
      <label>Pasted Accounts<textarea name="accounts_text" rows="10" placeholder="username:password" data-account-import-text></textarea></label>
      <div class="actions">
        <button class="button" type="button" data-preview-account-import>Preview parsed rows</button>
        <button class="button primary" disabled data-confirm-account-import>Import confirmed rows</button>
      </div>
      <div class="preview-box" data-account-import-preview></div>
    </form>
  </div>
</div>
<% } %>

<div class="modal" id="account-export-modal" hidden>
  <div class="modal-panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Export</p>
        <h2>Export Selected</h2>
      </div>
      <button class="icon-button" type="button" data-close-modal>Close</button>
    </div>
    <div class="form-grid">
      <p class="notice">TXT export contains sensitive account data. Keep the downloaded file private.</p>
      <label>Export Format Preset<select form="account-action-form" name="export_format" data-export-format>
        <option value="username_password">username:password</option>
        <option value="username_password_bank_pin">username:password:bank_pin</option>
        <option value="username_password_otp">username:password:otp</option>
        <option value="username_password_bank_pin_otp">username:password:bank_pin:otp</option>
        <option value="username_password_recovery">username:password:recovery_email:recovery_password</option>
        <option value="email_password">email:password</option>
        <option value="email_password_recovery">email:password:recovery_email:recovery_password</option>
        <option value="jagex_email_password">jagex_email:jagex_password</option>
        <option value="legacy_to_jagex">legacy_login:legacy_password:jagex_email:jagex_password</option>
        <option value="full">full</option>
        <option value="custom">custom</option>
      </select></label>
      <label>Export Scope<select form="account-action-form" name="export_scope"><option value="selected">Export selected only</option><option value="filtered">Export all filtered results</option></select></label>
      <label>Delimiter<input form="account-action-form" name="delimiter" value="<%= settings.default_export_delimiter || ':' %>"></label>
      <label>Custom fields / order<input form="account-action-form" name="custom_fields" placeholder="username,password,otp,proxy"></label>
      <p class="muted">Allowed custom fields include username, password, email, jagex_password, bank_pin, otp, recovery_email, recovery_password, proxy, category, country, status, notes.</p>
      <div class="form-grid two">
        <label class="check"><input form="account-action-form" type="checkbox" name="include_sensitive" value="no"> Exclude sensitive fields</label>
        <label class="check"><input form="account-action-form" type="checkbox" name="include_account_type" value="yes"> Include account type</label>
        <label class="check"><input form="account-action-form" type="checkbox" name="include_proxy" value="yes"> Include proxy</label>
        <label class="check"><input form="account-action-form" type="checkbox" name="include_notes" value="yes"> Include notes</label>
        <label class="check"><input form="account-action-form" type="checkbox" name="include_otp_secret" value="yes"> Include OTP secret</label>
      </div>
      <% if (isLimitedAccess) { %>
        <input form="account-action-form" type="hidden" name="post_export_action" value="keep">
        <p class="notice">Private-build locked users cannot export account data.</p>
      <% } else { %>
        <label>After export<select form="account-action-form" name="post_export_action" data-post-export-action><option value="keep">No, keep them</option><option value="archive">Archive them</option><option value="delete">Delete them permanently</option></select></label>
        <label class="check"><input form="account-action-form" type="checkbox" name="delete_after_export" value="yes" data-delete-after-export> Enable delete-after-export confirmation</label>
        <div class="notice danger delete-confirm-block" hidden>
          <p>This will permanently delete the selected accounts from your account list after export. This cannot be recovered.</p>
          <label class="check"><input form="account-action-form" type="checkbox" name="confirm_delete_after_export" value="yes"> I understand this permanently deletes these accounts and cannot be recovered.</label>
          <label>Type DELETE to confirm<input form="account-action-form" name="confirm_delete_after_export_text" placeholder="DELETE" autocomplete="off"></label>
        </div>
      <% } %>
      <button class="button primary" form="account-action-form" formaction="/accounts/export">Download TXT</button>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
