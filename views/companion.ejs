<%- include('partials/head') %>
<section class="helper-hero">
  <article class="panel helper-status-card">
    <div class="panel-head">
      <div>
        <p class="eyebrow">GS Agent</p>
        <h2>Paired Devices</h2>
      </div>
      <span class="status <%= helper.connected ? 'ready' : 'needs_review' %>"><%= helper.statusLabel %></span>
    </div>
    <div class="helper-detail-grid">
      <p class="row-line"><span>Primary device</span><strong><%= helper.device && helper.device.device_name ? helper.device.device_name : 'Not connected' %></strong></p>
      <p class="row-line"><span>Last seen</span><strong><%= helper.lastHeartbeat ? new Date(helper.lastHeartbeat).toLocaleString() : 'Never' %></strong></p>
      <p class="row-line"><span>Version</span><strong><%= helper.helperVersion %></strong></p>
      <p class="row-line"><span>Active jobs</span><strong><%= stats.active_jobs || 0 %></strong></p>
      <p class="row-line"><span>Live sessions</span><strong><%= stats.running_instances || 0 %></strong></p>
      <p class="row-line"><span>Safe host/IP label</span><strong>Not collected</strong></p>
      <p class="row-line"><span>Token storage</span><strong><%= helper.tokenStatus %></strong></p>
    </div>
    <p class="notice">Pair each PC once. The device token stays on that PC until you revoke it, clear local app data, or move to a different computer. New computers count against your subscription device limit.</p>
    <form method="post" action="/companion/pairing-code">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="button primary">Create Pairing Code</button>
    </form>
    <% if (!access.gates.addDevice) { %>
      <p class="notice">Connected device limit reached for your tier. You can still refresh this same GS Agent install, but pairing a different computer will be blocked until a device slot is available.</p>
    <% } %>
    <% if (pairingCode) { %>
      <div class="code-box">
        <span>Pairing code</span>
        <strong><%= pairingCode.code %></strong>
        <small>Expires <%= new Date(pairingCode.expiresAt).toLocaleString() %></small>
      </div>
    <% } else { %>
      <p class="muted">Pairing codes expire after 10 minutes and are stored only as hashes server-side.</p>
    <% } %>
  </article>

  <article class="panel download-card">
    <p class="eyebrow">GS Agent + GS Browser Automator</p>
    <h2>One app, two modules</h2>
    <p class="muted">GS Agent starts and monitors local client tools. GS Browser Automator runs visible browser jobs. Both use the same paired device slot.</p>
    <div class="actions">
      <a class="button primary" href="/setup">Setup Wizard</a>
      <a class="button" href="/downloads">Download GS Agent</a>
      <a class="button" href="/setup-guide">Setup Guide</a>
      <a class="button" href="/clients">Launch Profiles</a>
      <a class="button" href="/instances">Live Sessions</a>
      <a class="button" href="/local-jobs">Local Jobs</a>
      <span class="tag"><%= download.available ? `v${download.version}` : 'Coming soon' %></span>
    </div>
  </article>
</section>

<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Automation Agent Flow</p>
      <h2>How GS Agent powers paid automation</h2>
    </div>
    <a class="button small" href="/compatibility">Compatibility Matrix</a>
  </div>
  <div class="setup-steps compact">
    <article class="panel mini-card"><div class="step-num">1</div><h2>Pair device</h2><p class="muted">Connect this PC to your Discord-owned workspace with a short-lived pairing code.</p></article>
    <article class="panel mini-card"><div class="step-num">2</div><h2>Queue jobs</h2><p class="muted">Browser Automator, launch, detect, and snapshot requests are queued as Local Jobs.</p></article>
    <article class="panel mini-card"><div class="step-num">3</div><h2>Run locally</h2><p class="muted">GS Agent opens configured local clients and GS Browser Automator opens visible browsers on your PC.</p></article>
    <article class="panel mini-card"><div class="step-num">4</div><h2>Pause safely</h2><p class="muted">CAPTCHA, 2FA, and verification steps require manual user completion.</p></article>
    <article class="panel mini-card"><div class="step-num">5</div><h2>Report status</h2><p class="muted">Jobs, live sessions, screenshots, and events sync back without exposing secrets.</p></article>
  </div>
</section>

<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Feature Status</p>
      <h2>GS Agent Foundation</h2>
    </div>
    <span class="tag">One-time pairing</span>
  </div>
  <div class="checklist-grid">
    <p class="row-line"><span>One-time pairing</span><strong>Working</strong></p>
    <p class="row-line"><span>Same install re-pair</span><strong>Reuses device slot</strong></p>
    <p class="row-line"><span>New computer pairing</span><strong>Tier limited</strong></p>
    <p class="row-line"><span>Heartbeat and job queue</span><strong>Working</strong></p>
    <p class="row-line"><span>Opt-in client detection</span><strong>Working starter</strong></p>
    <p class="row-line"><span>Browser Automator jobs</span><strong>Working starter</strong></p>
    <p class="row-line"><span>Live snapshots</span><strong>Placeholder</strong></p>
    <p class="row-line"><span>Controlled field fill</span><strong>Working starter</strong></p>
    <p class="row-line"><span>CAPTCHA or security bypass</span><strong>Never</strong></p>
  </div>
</section>

<section class="metric-grid dashboard-metrics">
  <article class="metric"><span>Connected Devices</span><strong><%= stats.connected_devices || 0 %></strong></article>
  <article class="metric"><span>Active Jobs</span><strong><%= stats.active_jobs || 0 %></strong></article>
  <article class="metric"><span>Live Sessions</span><strong><%= stats.running_instances || 0 %></strong></article>
</section>

<section class="panel">
  <div class="panel-head">
  <h2>GS Agent Devices</h2>
    <span class="tag"><%= devices.length %> device(s)</span>
  </div>
  <table>
    <thead><tr><th>Name</th><th>Status</th><th>Role</th><th>Version</th><th>Paired</th><th>Last Seen</th><th>Capabilities</th><th>Screenshots</th><th>Actions</th></tr></thead>
    <tbody>
      <% devices.forEach(device => { %>
        <tr>
          <td><input class="table-input" form="device-<%= device.id %>" name="device_name" value="<%= device.device_name || `Device ${device.id}` %>"></td>
          <td><span class="status <%= device.status %>"><%= device.status %></span></td>
          <td><%= device.device_role === 'agent' ? 'GS Agent' : device.device_role === 'browser' ? 'GS Browser' : 'Agent + Browser' %></td>
          <td><%= device.companion_version || 'Unknown' %></td>
          <td><%= device.paired_at ? new Date(device.paired_at).toLocaleString() : 'Unknown' %></td>
          <td><%= device.last_seen_at ? new Date(device.last_seen_at).toLocaleString() : 'Never' %></td>
          <td>
            <span class="tag">Heartbeat</span>
            <span class="tag">Jobs</span>
            <span class="tag">Client status</span>
            <span class="tag"><%= device.allow_screenshots ? 'Snapshots opt-in' : 'Snapshots off' %></span>
          </td>
          <td><label class="check"><input form="device-<%= device.id %>" type="checkbox" name="allow_screenshots" value="yes" <%= device.allow_screenshots ? 'checked' : '' %>> Opt-in</label></td>
          <td>
            <form id="device-<%= device.id %>" method="post" action="/companion/devices/<%= device.id %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="button small">Save</button>
            </form>
            <% if (device.status !== 'revoked') { %>
              <form method="post" action="/companion/devices/<%= device.id %>/revoke" data-confirm="Revoke this connected device?">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="button small danger">Revoke Device</button>
              </form>
            <% } else { %>
              <span class="tag danger">Revoked</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
      <% if (!devices.length) { %><tr><td colspan="9"><p class="muted">No GS Agent devices paired yet.</p></td></tr><% } %>
    </tbody>
  </table>
</section>

<section class="panel">
  <div class="panel-head">
    <h2>Local Jobs</h2>
    <a class="button small" href="/local-jobs">Open Local Jobs</a>
  </div>
  <table>
    <thead><tr><th>Created</th><th>Automation</th><th>Status</th><th>Device</th><th>Job</th></tr></thead>
    <tbody>
      <% jobs.forEach(job => { %>
        <tr>
          <td><%= new Date(job.created_at).toLocaleString() %></td>
          <td><strong><%= job.workflow_name || jobTypeLabel(job.job_type) %></strong><br><span class="muted"><%= job.job_type %></span></td>
          <td><span class="status <%= job.status %>"><%= job.status %></span></td>
          <td><%= job.companion_device_id || 'Any paired device' %></td>
          <td><% if (job.workflow_run_id) { %><a class="button small" href="/workflows/runs/<%= job.workflow_run_id %>">Live Status</a><% } %></td>
        </tr>
      <% }) %>
      <% if (!jobs.length) { %><tr><td colspan="5"><p class="muted">No browser automation jobs queued yet.</p></td></tr><% } %>
    </tbody>
  </table>
</section>

<section class="content-grid">
  <article class="panel">
    <p class="eyebrow">Live Status</p>
    <h2>Local Client Status</h2>
    <% if (!helper.connected) { %>
      <p class="notice">Download and pair GS Agent to monitor clients and run browser tasks.</p>
      <div class="actions">
        <a class="button primary" href="/downloads">Go to Downloads</a>
        <a class="button" href="/companion">Pair Device</a>
        <a class="button" href="/setup-guide">View Setup Guide</a>
      </div>
    <% } %>
    <% if (clientStatuses.length) { %>
      <table>
        <thead><tr><th>Device</th><th>Process</th><th>Window</th><th>Status</th><th>Last Seen</th></tr></thead>
        <tbody>
          <% clientStatuses.forEach(status => { %>
            <tr>
              <td><%= status.device_name || 'Device' %></td>
              <td><%= status.process_name || 'Future detector' %></td>
              <td><%= status.window_title || '' %></td>
              <td><span class="status <%= status.running ? 'ready' : 'blocked' %>"><%= status.running ? 'client open' : 'client closed' %></span></td>
              <td><%= new Date(status.last_seen_at).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p class="muted">No client status reported yet. Open Live Sessions after pairing GS Agent.</p>
    <% } %>
    <div class="actions"><a class="button small" href="/instances">Open Live Sessions</a></div>
  </article>

  <article class="panel">
    <p class="eyebrow">Snapshot Placeholder</p>
    <h2>Optional Screenshot Preview</h2>
    <% if (snapshot) { %>
      <p class="row-line"><span>Latest snapshot</span><strong><%= new Date(snapshot.created_at).toLocaleString() %></strong></p>
      <p class="row-line"><span>Window</span><strong><%= snapshot.window_title || 'Not provided' %></strong></p>
      <p class="row-line"><span>Size</span><strong><%= snapshot.image_size %> bytes</strong></p>
    <% } else { %>
      <p class="notice">No snapshot uploaded yet.</p>
    <% } %>
    <p class="muted">Screenshots remain opt-in and must not capture passwords, private browser tabs, or the full desktop.</p>
  </article>
</section>

<section class="content-grid">
  <article class="panel">
    <p class="eyebrow">Browser Automator</p>
    <h2>Controlled browser automation</h2>
    <p class="muted">Browser Automator is the main product direction. Jobs are queued from the website, run locally in a visible browser, and must pause when manual verification is required.</p>
    <div class="checklist-grid">
      <p class="row-line"><span>CAPTCHA bypass</span><strong>Never</strong></p>
      <p class="row-line"><span>User-triggered credential fill</span><strong>Allowed for owner data</strong></p>
      <p class="row-line"><span>Auto-submit sensitive forms</span><strong>Manual review required</strong></p>
      <p class="row-line"><span>2FA/security bypass</span><strong>Never</strong></p>
    </div>
  </article>

  <article class="panel">
    <p class="eyebrow">Future Architecture</p>
    <h2>User-Triggered Browser Assist</h2>
    <ul class="helper-list">
      <li>Select account inside GS Account Manager.</li>
      <li>Open a visible automation browser from GS Browser Automator.</li>
      <li>Click Fill current page to fill visible fields with the selected account's stored login data.</li>
      <li>If CAPTCHA or security checks appear, stop and complete them manually.</li>
      <li>User reviews the page and clicks submit themselves.</li>
    </ul>
  </article>
</section>
<%- include('partials/foot') %>
