<%- include('partials/head') %>
<section class="content-grid">
  <form method="post" action="/imports/preview" enctype="multipart/form-data" class="panel form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2>TXT Import</h2>
    <label>Account Type<select name="account_type"><% accountTypes.forEach(t => { %><option value="<%= t %>" <%= options.account_type === t ? 'selected' : '' %>><%= t %></option><% }) %></select></label>
    <label>Delimiter<input name="delimiter" value="<%= options.delimiter || ':' %>"></label>
    <label>Category<input name="category" value="<%= options.category || '' %>"></label>
    <label>Country Code<input name="country_code" maxlength="2" value="<%= options.country_code || '' %>"></label>
    <label>Default Status<select name="status"><% accountStatuses.forEach(s => { %><option value="<%= s %>" <%= options.status === s ? 'selected' : '' %>><%= s %></option><% }) %></select></label>
    <label>Duplicates<select name="duplicate_mode"><option value="skip">Skip duplicate username</option><option value="update" <%= options.duplicate_mode === 'update' ? 'selected' : '' %>>Update duplicate</option></select></label>
    <label>Upload TXT file<input type="file" name="accounts_file" accept=".txt,text/plain"></label>
    <textarea name="accounts_text" rows="12" placeholder="username:password&#10;username:password:otp&#10;username:password:bank_pin:otp&#10;username:password:otp:notes"><%= options.accounts_text || '' %></textarea>
    <button class="button">Preview import</button>
  </form>
  <form method="post" action="/exports/preview" class="panel form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2>TXT / CSV Export</h2>
    <label>Account Type<select name="account_type"><% accountTypes.forEach(t => { %><option value="<%= t %>"><%= t %></option><% }) %></select></label>
    <label>Format<select name="format">
      <% exportFormats.forEach(format => { %>
        <option value="<%= format %>" <%= (options.format || settings.preferred_export_format) === format ? 'selected' : '' %>><%= format.replace(/_/g, ' ') %></option>
      <% }) %>
    </select></label>
    <label>After export<select name="export_action">
      <option value="keep">Keep accounts</option>
      <option value="mark_exported">Mark exported</option>
      <option value="archive">Archive</option>
      <option value="delete">Delete requested, review only</option>
    </select></label>
    <label class="check"><input type="checkbox" name="confirm_export_action" value="yes"> Apply selected post-export action</label>
    <p class="muted">Delete is never automatic. Selecting delete only writes a review log entry.</p>
    <button class="button">Prepare export</button>
  </form>
</section>
<% if (stats) { %>
  <section class="metric-grid import-stats">
    <article class="metric"><span>Valid</span><strong><%= stats.valid %></strong></article>
    <article class="metric"><span>Duplicates</span><strong><%= stats.duplicate %></strong></article>
    <article class="metric"><span>Invalid</span><strong><%= stats.invalid %></strong></article>
  </section>
<% } %>
<% if (preview) { %>
  <section class="panel">
    <div class="panel-head"><h2>Import Preview</h2></div>
    <table><thead><tr><th>Line</th><th>Username</th><th>OTP</th><th>Notes</th><th>Duplicate</th><th>Valid</th><th>Error</th></tr></thead><tbody>
      <% preview.forEach(row => { %><tr><td><%= row.line %></td><td><%= row.username %></td><td><%= row.otp_secret ? 'yes' : 'no' %></td><td><%= row.notes || '' %></td><td><%= row.duplicate ? 'yes' : 'no' %></td><td><%= row.valid ? 'yes' : 'no' %></td><td><%= row.error || '' %></td></tr><% }) %>
    </tbody></table>
    <form method="post" action="/imports/commit">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% ['account_type','delimiter','category','country_code','status','duplicate_mode'].forEach(key => { %><input type="hidden" name="<%= key %>" value="<%= options[key] || '' %>"><% }) %>
      <textarea hidden name="accounts_text"><%= options.accounts_text || '' %></textarea>
      <button class="button primary">Confirm import</button>
    </form>
  </section>
<% } %>
<% if (exportRows) { %>
  <section class="panel">
    <h2>Export Preview</h2>
    <% if (options.export_action === 'delete') { %><p class="notice danger">Delete was requested for review only. No records were deleted.</p><% } %>
    <% if (options.confirm_export_action === 'yes' && options.export_action !== 'keep') { %><p class="notice">Post-export action applied: <%= options.export_action %>.</p><% } %>
    <textarea rows="14" readonly><%= exportRows.join('\n') %></textarea>
  </section>
<% } %>
<%- include('partials/foot') %>
