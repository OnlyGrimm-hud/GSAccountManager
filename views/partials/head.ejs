<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | <%= appName %></title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<% const showAppShell = user && (typeof lockedShell === 'undefined' || !lockedShell); %>
<% if (showAppShell) { %>
  <aside class="sidebar">
    <a class="brand" href="/"><span>GS</span><strong><%= appName %></strong></a>
    <nav>
      <p class="nav-label">My Workspace</p>
      <a class="<%= path === '/' ? 'active' : '' %>" href="/">Dashboard</a>
      <a class="<%= path.startsWith('/accounts') ? 'active' : '' %>" href="/accounts">Accounts</a>
      <a class="<%= path.startsWith('/proxies') ? 'active' : '' %>" href="/proxies">Proxies</a>
      <% if (hasFullAccess) { %>
        <a class="<%= path.startsWith('/setup') ? 'active' : '' %>" href="/setup">Setup</a>
        <a class="<%= path.startsWith('/companion') ? 'active' : '' %>" href="/companion">Client Monitor</a>
        <a class="<%= path.startsWith('/workflow') ? 'active' : '' %>" href="/workflows">Browser Automator</a>
        <a class="<%= path.startsWith('/instances') ? 'active' : '' %>" href="/instances">Live Sessions</a>
        <a class="<%= path.startsWith('/local-jobs') ? 'active' : '' %>" href="/local-jobs">Local Jobs</a>
        <a class="<%= path.startsWith('/downloads') ? 'active' : '' %>" href="/downloads">Downloads</a>
        <a class="<%= path.startsWith('/compatibility') ? 'active' : '' %>" href="/compatibility">Compatibility</a>
      <% } %>
      <a class="<%= path.startsWith('/logs') ? 'active' : '' %>" href="/logs">Logs</a>
      <% if (hasFullAccess) { %><a class="<%= path.startsWith('/settings') ? 'active' : '' %>" href="/settings">Settings</a><% } %>
      <% if (isAdmin) { %>
        <p class="nav-label">Admin</p>
        <a class="<%= path === '/admin' ? 'active' : '' %>" href="/admin">Admin Dashboard</a>
        <a class="<%= path.startsWith('/admin/users') ? 'active' : '' %>" href="/admin/users">Users</a>
        <a class="<%= path.startsWith('/admin/subscriptions') ? 'active' : '' %>" href="/admin/subscriptions">Subscriptions</a>
        <a class="<%= path.startsWith('/admin/downloads') ? 'active' : '' %>" href="/admin/downloads">Downloads Manager</a>
        <a class="<%= path.startsWith('/admin/logs') ? 'active' : '' %>" href="/admin/logs">Platform Logs</a>
        <a class="<%= path.startsWith('/admin/system') ? 'active' : '' %>" href="/admin/system">System Health</a>
      <% } %>
    </nav>
  </aside>
  <main class="shell">
    <header class="topbar">
      <div>
        <p class="eyebrow">Account storage and paid local automation</p>
        <h1><%= title %></h1>
      </div>
      <div class="user-menu">
        <% if (user.avatar) { %>
          <img class="avatar" src="<%= user.avatar %>" alt="">
        <% } else { %>
          <span class="avatar avatar-fallback"><%= (user.globalName || user.username || 'U').slice(0, 1).toUpperCase() %></span>
        <% } %>
        <span><%= user.globalName || user.username %></span>
        <% if (isAdmin) { %><span class="tag admin-badge">Admin</span><% } %>
        <% if (isLimitedAccess) { %><span class="tag">Limited</span><% } %>
        <form method="post" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button small">Logout</button>
        </form>
      </div>
    </header>
<% } else { %>
  <main class="auth-shell">
<% } %>
