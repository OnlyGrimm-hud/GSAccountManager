<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | <%= appName %></title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<% if (user) { %>
  <aside class="sidebar">
    <a class="brand" href="/"><span>GS</span><strong><%= appName %></strong></a>
    <nav>
      <a class="<%= path === '/' ? 'active' : '' %>" href="/">Dashboard</a>
      <a class="<%= path.startsWith('/accounts') ? 'active' : '' %>" href="/accounts">Accounts</a>
      <a class="<%= path.startsWith('/workflow') ? 'active' : '' %>" href="/workflow">Workflow</a>
      <a class="<%= path.startsWith('/proxies') ? 'active' : '' %>" href="/proxies">Proxies</a>
      <a class="<%= path.startsWith('/local-helper') || path.startsWith('/downloads/helper') ? 'active' : '' %>" href="/local-helper">Local Helper</a>
      <a class="<%= path.startsWith('/imports-exports') ? 'active' : '' %>" href="/imports-exports">Imports / Exports</a>
      <a class="<%= path.startsWith('/settings') ? 'active' : '' %>" href="/settings">Settings</a>
      <a class="<%= path.startsWith('/logs') ? 'active' : '' %>" href="/logs">Logs</a>
    </nav>
  </aside>
  <main class="shell">
    <header class="topbar">
      <div>
        <p class="eyebrow">Manual workflow dashboard</p>
        <h1><%= title %></h1>
      </div>
      <div class="user-menu">
        <% if (user.avatar) { %>
          <img class="avatar" src="<%= user.avatar %>" alt="">
        <% } else { %>
          <span class="avatar avatar-fallback"><%= (user.globalName || user.username || 'U').slice(0, 1).toUpperCase() %></span>
        <% } %>
        <span><%= user.globalName || user.username %></span>
        <form method="post" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button small">Logout</button>
        </form>
      </div>
    </header>
<% } else { %>
  <main class="auth-shell">
<% } %>
