<%- include('partials/head') %>
<section class="panel">
  <form method="get" class="filters">
    <select name="account_id">
      <% accounts.forEach(account => { %><option value="<%= account.id %>" <%= selected && selected.id === account.id ? 'selected' : '' %>><%= account.username %> - <%= account.status %></option><% }) %>
    </select>
    <button class="button">Load</button>
  </form>
</section>
<% if (selected) { %>
  <section class="workflow-hero">
    <div>
      <p class="eyebrow"><%= selected.account_type %> account</p>
      <h2><%= selected.display_name || selected.username %></h2>
      <span class="status <%= selected.status %>"><%= selected.status %></span>
    </div>
    <div class="actions">
      <button class="button copy-api" data-url="/accounts/<%= selected.id %>/copy/username">Copy username</button>
      <button class="button copy-api" data-url="/accounts/<%= selected.id %>/copy/password">Copy password</button>
      <% if (selected.otp_secret_encrypted) { %><button class="button copy-api" data-url="/accounts/<%= selected.id %>/copy/otp_code">Copy OTP</button><% } %>
    </div>
  </section>
  <section class="steps">
    <% ['Prepare account','Create target email manually','Login + authenticator manually','Upgrade manually','Save result locally'].forEach((step, index) => { %>
      <article class="panel step">
        <span class="step-num"><%= index + 1 %></span>
        <h2><%= step %></h2>
        <p class="muted"><%= index === 0 ? 'Confirm saved fields, proxy assignment, and OTP availability.' : 'Use the copied values manually in external pages only when you choose to.' %></p>
        <div class="actions">
          <% if (index === 1) { %><a class="button small" target="_blank" rel="noopener" href="https://outlook.live.com/">Open Outlook</a><% } %>
          <% if (index === 2 || index === 3) { %><a class="button small" target="_blank" rel="noopener" href="https://www.jagex.com/">Open Jagex</a><% } %>
        </div>
      </article>
    <% }) %>
  </section>
  <section class="panel">
    <h2>Mark Workflow Status</h2>
    <form method="post" action="/workflow/<%= selected.id %>/status" class="actions">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% ['in_progress','needs_review','blocked','skipped','upgraded'].forEach(status => { %><button class="button" name="status" value="<%= status %>"><%= status %></button><% }) %>
    </form>
  </section>
<% } else { %>
  <section class="panel"><p class="muted">No accounts are available yet.</p></section>
<% } %>
<%- include('partials/foot') %>
