<%- include('partials/head') %>
<section class="panel">
  <form method="get" class="filters compact">
    <select name="account_id">
      <% accounts.forEach(account => { %><option value="<%= account.id %>" <%= selected && selected.id === account.id ? 'selected' : '' %>><%= account.display_name || account.legacy_login || account.username %> - <%= account.status %></option><% }) %>
    </select>
    <button class="button">Load</button>
  </form>
</section>
<% if (selected) { %>
  <section class="workflow-hero">
    <div>
      <p class="eyebrow"><%= selected.account_type %> manual workflow</p>
      <h2><%= selected.display_name || selected.legacy_login || selected.username %></h2>
      <p class="muted"><%= nextStep %></p>
      <div class="actions">
        <span class="status <%= selected.status %>"><%= selected.status %></span>
        <span class="tag"><%= selected.email_creation_status %> email</span>
        <span class="tag"><%= selected.upgrade_status %> upgrade</span>
      </div>
    </div>
    <div class="copy-grid tight">
      <button class="button small copy-api" data-url="/accounts/<%= selected.id %>/copy/legacy_login">Copy login</button>
      <button class="button small copy-api" data-url="/accounts/<%= selected.id %>/copy/legacy_password">Copy password</button>
      <% if (selected.otp_secret_encrypted) { %><button class="button small copy-api" data-url="/accounts/<%= selected.id %>/copy/otp_code">Copy OTP</button><% } %>
    </div>
  </section>
  <section class="panel helper-mode-panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Browser Mode</p>
        <h2><%= helper.connected ? 'Open with Companion' : 'Open in this browser' %></h2>
        <p class="muted"><%= helper.connected ? 'Uses assigned proxy if selected.' : 'No proxy control from website.' %></p>
      </div>
      <a class="button small" href="/companion">Companion</a>
    </div>
    <% if (!helper.connected && settings.warn_before_opening_without_helper === 'true') { %>
      <p class="notice">To use Chrome with proxies, install and connect GS Account Manager Companion. Website-only opens use your normal browser session.</p>
    <% } %>
    <% if (settings.show_proxy_mode_before_open !== 'false') { %>
      <div class="proxy-mode-grid">
        <p class="row-line"><span>Browser mode</span><strong><%= proxyMode.browserMode %></strong></p>
        <p class="row-line"><span>Helper connected</span><strong><%= proxyMode.helperConnected %></strong></p>
        <p class="row-line"><span>Selected proxy type</span><strong><%= proxyMode.proxyType %></strong></p>
        <p class="row-line"><span>Selected proxy</span><strong><%= proxyMode.proxyEndpoint %></strong></p>
        <p class="row-line"><span>Direct fallback</span><strong><%= proxyMode.directFallback %></strong></p>
      </div>
      <p class="muted"><%= proxyMode.modeDescription %></p>
      <div class="assist-panel">
        <p class="eyebrow">Assisted Actions</p>
        <div class="actions">
          <button class="button small" type="button" disabled>Helper Required</button>
          <button class="button small" type="button" disabled>Fill Visible Fields</button>
          <span class="tag">Requires your click</span>
          <span class="tag">You stay in control</span>
        </div>
      </div>
    <% } %>
  </section>
  <section class="steps">
    <% ['Prepare account','Create target email manually','Login + authenticator manually','Upgrade manually','Save result locally'].forEach((step, index) => { %>
      <article class="panel step">
        <span class="step-num"><%= index + 1 %></span>
        <h2><%= step %></h2>
        <p class="muted"><%= index === 0 ? 'Confirm saved fields, proxy assignment, and OTP availability.' : 'Use copied values manually in external pages only when you choose to.' %></p>
        <div class="actions">
          <% if (index === 1) { %><a class="button small" target="_blank" rel="noopener" href="<%= settings.email_signup_url || 'https://signup.live.com/' %>"><%= helper.connected ? 'Open with Companion' : 'Open in this browser' %></a><% } %>
          <% if (index === 2) { %><a class="button small" target="_blank" rel="noopener" href="<%= settings.email_signin_url || 'https://outlook.live.com/' %>"><%= helper.connected ? 'Open with Companion' : 'Open in this browser' %></a><% } %>
          <% if (index === 3) { %><a class="button small" target="_blank" rel="noopener" href="<%= settings.upgrade_url || 'https://account.jagex.com/' %>"><%= helper.connected ? 'Open with Companion' : 'Open in this browser' %></a><% } %>
        </div>
      </article>
    <% }) %>
  </section>
  <section class="panel">
    <h2>Mark Workflow Status</h2>
    <form method="post" action="/workflow/<%= selected.id %>/status" class="actions">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% ['in_progress','needs_review','blocked','skipped','upgraded','exported','archived'].forEach(status => { %><button class="button" name="status" value="<%= status %>"><%= status.replace('_', ' ') %></button><% }) %>
    </form>
  </section>
<% } else { %>
  <section class="panel"><p class="muted">No accounts are available yet.</p></section>
<% } %>
<%- include('partials/foot') %>
