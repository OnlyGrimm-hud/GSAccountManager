<%- include('../partials/head') %>
<section class="workflow-hero">
  <div>
    <p class="eyebrow">Job Status</p>
    <h2><%= run.workflow_name || 'Browser automation job' %></h2>
    <p class="muted">GS Browser Automator job <%= run.companion_job_id || 'not queued' %> is <%= run.companion_job_status || run.status %>.</p>
  </div>
  <span class="status <%= run.status %>"><%= run.status %></span>
</section>

<section class="content-grid">
  <article class="panel">
    <h2>Job Details</h2>
    <div class="checklist-grid">
      <p class="row-line"><span>Account</span><strong><%= run.account_display_name || run.account_legacy_login || run.account_username || 'None' %></strong></p>
      <p class="row-line"><span>Proxy</span><strong><%= run.proxy_host ? `${run.proxy_name || ''} ${run.proxy_type || ''} ${run.proxy_host}:${run.proxy_port}` : 'Account/default or direct' %></strong></p>
      <p class="row-line"><span>GS Agent Device</span><strong><%= run.companion_device_name || 'Any paired device' %></strong></p>
      <p class="row-line"><span>Created</span><strong><%= new Date(run.created_at).toLocaleString() %></strong></p>
      <p class="row-line"><span>Started</span><strong><%= run.started_at ? new Date(run.started_at).toLocaleString() : 'Not started' %></strong></p>
      <p class="row-line"><span>Completed</span><strong><%= run.completed_at ? new Date(run.completed_at).toLocaleString() : 'Not completed' %></strong></p>
    </div>
    <div class="actions">
      <form method="post" action="/workflows/runs/<%= run.id %>/continue">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="button">Continue After Manual Check</button>
      </form>
      <form method="post" action="/workflows/runs/<%= run.id %>/cancel" data-confirm="Cancel this browser automation job?">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="button danger">Cancel Job</button>
      </form>
    </div>
  </article>

  <article class="panel">
    <h2>Latest Snapshot</h2>
    <% if (snapshot) { %>
      <p class="row-line"><span>Time</span><strong><%= new Date(snapshot.created_at).toLocaleString() %></strong></p>
      <p class="row-line"><span>Window</span><strong><%= snapshot.window_title || 'Not provided' %></strong></p>
      <p class="row-line"><span>Size</span><strong><%= snapshot.image_size %> bytes</strong></p>
    <% } else { %>
      <p class="notice">No snapshot uploaded yet.</p>
    <% } %>
    <p class="muted">Snapshots are opt-in and must not capture passwords, private tabs, or the full desktop.</p>
  </article>

  <article class="panel">
    <h2>Run This Job Locally</h2>
    <div class="checklist-grid">
      <p class="row-line"><span>1. Open</span><strong>GS Agent</strong></p>
      <p class="row-line"><span>2. Click</span><strong>Fetch Next Job</strong></p>
      <p class="row-line"><span>3. Click</span><strong>Run Browser Automator Job</strong></p>
      <p class="row-line"><span>4. Pause</span><strong>Manual checks stay manual</strong></p>
    </div>
    <p class="notice">If the page asks for CAPTCHA, 2FA, email verification, phone verification, Cloudflare, or a security check, complete it yourself in the visible browser and then continue.</p>
    <div class="actions">
      <a class="button small" href="/local-jobs">Open Local Jobs</a>
      <a class="button small" href="/downloads">Open Downloads</a>
    </div>
  </article>
</section>

<section class="content-grid">
  <article class="panel">
    <h2>Automation Events</h2>
    <table>
      <thead><tr><th>Time</th><th>Type</th><th>Message</th></tr></thead>
      <tbody>
        <% events.forEach(event => { %><tr><td><%= new Date(event.created_at).toLocaleString() %></td><td><%= event.event_type %></td><td><%= event.message || '' %></td></tr><% }) %>
      </tbody>
    </table>
  </article>
  <article class="panel">
    <h2>GS Agent Events</h2>
    <table>
      <thead><tr><th>Time</th><th>Type</th><th>Message</th></tr></thead>
      <tbody>
        <% jobEvents.forEach(event => { %><tr><td><%= new Date(event.created_at).toLocaleString() %></td><td><%= event.event_type %></td><td><%= event.message || '' %></td></tr><% }) %>
      </tbody>
    </table>
  </article>
</section>
<%- include('../partials/foot') %>
