<%- include('partials/head') %>
<section class="panel narrow">
  <p class="eyebrow">Download</p>
  <h2>GS Agent for Windows</h2>
  <p class="notice"><%= download.available ? 'Your Windows installer is ready.' : 'Coming soon. The Windows local app installer is not published on this server yet.' %></p>
  <div class="helper-detail-grid">
    <p class="row-line"><span>Latest version</span><strong><%= download.version %></strong></p>
    <p class="row-line"><span>Release date</span><strong><%= download.releaseDate %></strong></p>
    <p class="row-line"><span>File size</span><strong><%= download.fileSize || 'Not available' %></strong></p>
  </div>
  <p class="muted">This route serves <strong>companion/dist/GS Agent Setup.exe</strong> when that packaged artifact exists on the deployment host. For local Windows testing, run <strong>npm run package:win</strong> inside the companion folder.</p>
  <div class="actions">
    <a class="button" href="/companion">Back to Client Monitor</a>
  </div>
</section>
<%- include('partials/foot') %>
