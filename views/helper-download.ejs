<%- include('partials/head') %>
<section class="panel narrow">
  <p class="eyebrow">Download</p>
  <h2>GS Account Manager Companion for Windows</h2>
  <p class="notice">Coming soon. The Windows helper installer is not published yet.</p>
  <div class="helper-detail-grid">
    <p class="row-line"><span>Latest version</span><strong><%= download.version %></strong></p>
    <p class="row-line"><span>Release date</span><strong><%= download.releaseDate %></strong></p>
    <p class="row-line"><span>File size</span><strong><%= download.fileSize || 'Not available' %></strong></p>
  </div>
  <p class="muted">When released, this route will provide the Windows package or redirect to the official release asset. It currently returns a clear placeholder instead of crashing.</p>
  <div class="actions">
    <a class="button" href="/companion">Back to Companion</a>
  </div>
</section>
<%- include('partials/foot') %>
