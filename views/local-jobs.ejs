<%- include('partials/head') %>
<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">GS Agent Queue</p>
      <h2>Local Jobs</h2>
    </div>
    <div class="actions">
      <a class="button" href="/setup">Setup</a>
      <a class="button" href="/companion">Client Monitor</a>
      <a class="button primary" href="/workflows">Browser Automator</a>
      <a class="button" href="/clients">Launch Profiles</a>
      <a class="button" href="/instances">Live Sessions</a>
    </div>
  </div>
  <p class="muted">Local jobs are commands queued for a paired GS Agent device. Jobs are user-scoped, visible, pausable, and safe-logged without passwords, OTP secrets, cookies, or tokens.</p>
  <% if (query.launch_job) { %>
    <p class="notice">Launch job <%= query.launch_job %> is queued. Open GS Agent, go to Jobs, click Fetch Next Job, then click Run Current Launch Job.</p>
  <% } %>
  <% if (query.workflow_job) { %>
    <p class="notice">Browser Automator job <%= query.workflow_job %> is queued. Open GS Agent, go to Jobs or GS Browser Automator, fetch the job, then run it visibly.</p>
  <% } %>
</section>

<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Automation Pipeline</p>
      <h2>Local job lifecycle</h2>
    </div>
    <span class="tag">Visible local automation</span>
  </div>
  <div class="status-lane">
    <span><strong>Queued</strong><br><small>Waiting for an eligible GS Agent device</small></span>
    <span><strong>Accepted / Running</strong><br><small>GS Agent is processing the job visibly</small></span>
    <span><strong>Waiting for User</strong><br><small>Manual verification or review is required</small></span>
    <span><strong>Completed / Failed</strong><br><small>Safe result details are logged</small></span>
  </div>
</section>

<section class="metric-grid dashboard-metrics">
  <article class="metric"><span>Total Jobs</span><strong><%= stats.total || 0 %></strong></article>
  <article class="metric"><span>Queued</span><strong><%= stats.queued || 0 %></strong></article>
  <article class="metric"><span>Running</span><strong><%= stats.running || 0 %></strong></article>
  <article class="metric"><span>Completed</span><strong><%= stats.completed || 0 %></strong></article>
  <article class="metric"><span>Failed</span><strong><%= stats.failed || 0 %></strong></article>
  <article class="metric"><span>Cancelled</span><strong><%= stats.cancelled || 0 %></strong></article>
</section>

<section class="panel">
  <form class="filters compact" method="get">
    <select name="status"><option value="">All Statuses</option><% companionJobStatuses.forEach(status => { %><option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option><% }) %></select>
    <select name="job_type"><option value="">All Job Types</option><% companionJobTypes.forEach(type => { %><option value="<%= type %>" <%= filters.job_type === type ? 'selected' : '' %>><%= jobTypeLabel(type) %></option><% }) %></select>
    <button class="button">Filter</button>
  </form>
  <div class="panel-head">
    <h2>Jobs</h2>
    <span class="tag"><%= jobs.length %> shown</span>
  </div>
  <table>
    <thead><tr><th>Created</th><th>Type</th><th>Status</th><th>Device</th><th>Target</th><th>Completed</th><th>Actions</th></tr></thead>
    <tbody>
      <% jobs.forEach(job => { %>
        <tr>
          <td><%= new Date(job.created_at).toLocaleString() %></td>
          <td><strong><%= jobTypeLabel(job.job_type) %></strong><br><span class="muted"><%= job.job_type %></span></td>
          <td><span class="status <%= job.status %>"><%= job.status %></span></td>
          <td><%= job.device_name || (job.companion_device_id ? `Device ${job.companion_device_id}` : 'Any paired device') %></td>
          <td>
            <strong><%= job.workflow_name || job.profile_name || job.instance_name || job.account_legacy_login || job.account_username || 'GS Agent' %></strong>
            <% if (job.proxy_host) { %><br><span class="muted">Proxy: <%= job.proxy_name || `${mask(job.proxy_host)}:${job.proxy_port}` %></span><% } %>
          </td>
          <td><%= job.completed_at ? new Date(job.completed_at).toLocaleString() : '' %></td>
          <td class="actions">
            <% if (['queued','accepted','running','paused','waiting_for_user'].includes(job.status)) { %>
              <form method="post" action="/local-jobs/<%= job.id %>/cancel" data-confirm="Cancel this local job?">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="button small danger">Cancel</button>
              </form>
            <% } else { %>
              <span class="tag">No action</span>
            <% } %>
            <% if (job.workflow_run_id) { %><a class="button small" href="/workflows/runs/<%= job.workflow_run_id %>">Live Status</a><% } %>
          </td>
        </tr>
      <% }) %>
      <% if (!jobs.length) { %><tr><td colspan="7"><p class="muted">No local jobs yet. Launch a client, run an automation, or request a snapshot to queue one.</p></td></tr><% } %>
    </tbody>
  </table>
</section>

<section class="content-grid">
  <article class="panel">
    <div class="panel-head">
      <h2>Browser Automator Jobs</h2>
      <span class="status working">Core focus</span>
    </div>
    <p class="muted">These jobs are the main paid automation path. They run through GS Browser Automator in a visible browser and pause for manual verification.</p>
    <div class="actions">
      <a class="button small" href="/workflows">Open Browser Automator</a>
      <a class="button small" href="/setup-guide">Read Setup Guide</a>
    </div>
  </article>
  <article class="panel">
    <div class="panel-head">
      <h2>Launch and Detection Jobs</h2>
      <span class="status partial">GS Agent</span>
    </div>
    <p class="muted">Launch profiles and client detection jobs help organize local sessions. GS does not inject into clients, read memory, or control gameplay.</p>
    <div class="actions">
      <a class="button small" href="/clients">Launch Profiles</a>
      <a class="button small" href="/instances">Live Sessions</a>
    </div>
  </article>
</section>

<section class="content-grid">
  <article class="panel">
    <div class="panel-head">
      <h2>Recent Job Events</h2>
      <span class="tag">safe details only</span>
    </div>
    <table>
      <thead><tr><th>Time</th><th>Job</th><th>Event</th><th>Message</th></tr></thead>
      <tbody>
        <% events.forEach(event => { %>
          <tr><td><%= new Date(event.created_at).toLocaleString() %></td><td><%= event.companion_job_id %> / <%= event.job_type || '' %></td><td><%= event.event_type %></td><td><%= event.message || '' %></td></tr>
        <% }) %>
        <% if (!events.length) { %><tr><td colspan="4"><p class="muted">No local job events yet.</p></td></tr><% } %>
      </tbody>
    </table>
  </article>

  <article class="panel">
    <div class="panel-head">
      <h2>Paired Devices</h2>
      <a class="button small" href="/companion">Manage</a>
    </div>
    <table>
      <thead><tr><th>Device</th><th>Status</th><th>Last Seen</th></tr></thead>
      <tbody>
        <% devices.forEach(device => { %>
          <tr><td><%= device.device_name || `Device ${device.id}` %></td><td><span class="status <%= device.status %>"><%= device.status %></span></td><td><%= device.last_seen_at ? new Date(device.last_seen_at).toLocaleString() : 'Never' %></td></tr>
        <% }) %>
        <% if (!devices.length) { %><tr><td colspan="3"><p class="muted">No paired devices.</p></td></tr><% } %>
      </tbody>
    </table>
  </article>
</section>
<%- include('partials/foot') %>
