<%- include('partials/head') %>
<section class="panel locked-panel">
  <div class="login-brand"><span>GS</span><strong>GS Account Manager</strong></div>
  <h2>Private build access is not active yet.</h2>
  <p class="muted">GS Account Manager is currently in private build/testing and will become a subscription-based tool.</p>
  <p class="muted">Your Discord account is connected, but account storage, proxy storage, exports, logs, and companion features stay locked until access is activated.</p>
  <p class="muted">An admin can activate your account when this workspace is ready for broader testing.</p>
  <form method="post" action="/logout">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button class="button">Logout</button>
  </form>
</section>
<%- include('partials/foot') %>
