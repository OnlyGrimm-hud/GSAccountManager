<%- include('partials/head') %>
<section class="panel">
  <div class="panel-head">
    <h2>Safe Activity Logs</h2>
  </div>
  <form class="filters compact" method="get">
    <input name="q" placeholder="Search logs" value="<%= filters.q || '' %>">
    <select name="action"><option value="">All actions</option><% actions.forEach(action => { %><option value="<%= action %>" <%= filters.action === action ? 'selected' : '' %>><%= action %></option><% }) %></select>
    <button class="button">Filter</button>
  </form>
  <table>
    <thead><tr><th>Time</th><% if (admin) { %><th>User</th><% } %><th>Action</th><th>Entity</th><th>Message</th></tr></thead>
    <tbody><% logs.forEach(log => { %><tr><td><%= new Date(log.created_at).toLocaleString() %></td><% if (admin) { %><td><%= log.log_username || 'System' %></td><% } %><td><%= log.action %></td><td><%= log.entity_type || '' %> <%= log.entity_id || '' %></td><td><%= log.message || '' %></td></tr><% }) %></tbody>
  </table>
</section>
<%- include('partials/foot') %>
