<%- include('partials/head') %>
<section class="panel">
  <h2>Safe Activity Logs</h2>
  <table>
    <thead><tr><th>Time</th><th>Action</th><th>Entity</th><th>Message</th></tr></thead>
    <tbody><% logs.forEach(log => { %><tr><td><%= new Date(log.created_at).toLocaleString() %></td><td><%= log.action %></td><td><%= log.entity_type || '' %> <%= log.entity_id || '' %></td><td><%= log.message || '' %></td></tr><% }) %></tbody>
  </table>
</section>
<%- include('partials/foot') %>
