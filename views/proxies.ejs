<%- include('partials/head') %>
<section class="metric-grid proxy-metrics">
  <% [['total','Total'],['assigned','Assigned'],['unassigned','Unassigned'],['online','Online'],['blocked','Blocked'],['review','Review']].forEach(item => { %>
    <article class="metric"><span><%= item[1] %></span><strong><%= counts[item[0]] || 0 %></strong></article>
  <% }) %>
</section>
<section class="content-grid">
  <form method="post" action="/proxies" class="panel form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2>Add Proxy</h2>
    <label>Type<select name="proxy_type"><% proxyTypes.forEach(t => { %><option value="<%= t %>" <%= t === 'HTTP' ? 'selected' : '' %>><%= t %></option><% }) %></select></label>
    <label>Host<input name="host"></label>
    <label>Port<input name="port" type="number" min="1" max="65535"></label>
    <label>Username<input name="username" type="password"></label>
    <label>Password<input name="password" type="password"></label>
    <label>Category<input name="category"></label>
    <label>Country Code<input name="country_code" maxlength="2"></label>
    <label>Status<select name="status"><% proxyStatuses.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %></select></label>
    <label>Notes<textarea name="notes"></textarea></label>
    <button class="button primary">Save proxy</button>
  </form>
  <form method="post" action="/proxies" class="panel form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2>Import Proxies</h2>
    <p class="muted">Formats: host:port, host:port:user:pass, http://user:pass@host:port</p>
    <label>Default Type<select name="proxy_type"><option value="HTTP">HTTP</option><option value="SOCKS5">SOCKS5</option></select></label>
    <textarea name="bulk" rows="10"></textarea>
    <button class="button">Import proxies</button>
  </form>
</section>
<section class="panel">
  <div class="panel-head">
    <h2>Saved Proxies</h2>
    <form method="post" action="/proxies/auto-assign">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="button">Auto assign HTTP proxies</button>
    </form>
  </div>
  <p class="muted">Max accounts per proxy: <%= settings.max_accounts_per_proxy || 5 %>. Proxy passwords stay hidden in tables.</p>
  <p class="notice">Proxy testing and selected-proxy TXT export are coming soon. The web app does not route its own traffic through user proxies.</p>
  <table>
    <thead><tr><th>Host</th><th>Port</th><th>Type</th><th>Category</th><th>Country</th><th>Status</th><th>Assigned</th><th>Notes</th><th>Credentials</th><th>Actions</th></tr></thead>
    <tbody>
      <% proxies.forEach(proxy => { %>
        <tr>
          <td><input class="table-input" form="proxy-<%= proxy.id %>" name="host" value="<%= proxy.host %>" required></td>
          <td><input class="table-input short" form="proxy-<%= proxy.id %>" name="port" type="number" min="1" max="65535" value="<%= proxy.port %>" required></td>
          <td><select form="proxy-<%= proxy.id %>" name="proxy_type"><% proxyTypes.forEach(type => { %><option value="<%= type %>" <%= proxy.proxy_type === type ? 'selected' : '' %>><%= type %></option><% }) %></select></td>
          <td><input class="table-input" form="proxy-<%= proxy.id %>" name="category" value="<%= proxy.category || '' %>"></td>
          <td><input class="table-input short" form="proxy-<%= proxy.id %>" name="country_code" maxlength="2" value="<%= proxy.country_code || '' %>"></td>
          <td><select form="proxy-<%= proxy.id %>" name="status"><% proxyStatuses.forEach(status => { %><option value="<%= status %>" <%= proxy.status === status ? 'selected' : '' %>><%= status %></option><% }) %></select></td>
          <td><%= proxy.assigned_count %></td>
          <td><input class="table-input" form="proxy-<%= proxy.id %>" name="notes" value="<%= proxy.notes || '' %>"></td>
          <td>
            <input class="table-input" form="proxy-<%= proxy.id %>" name="username" type="password" placeholder="new username">
            <input class="table-input" form="proxy-<%= proxy.id %>" name="password" type="password" placeholder="new password">
          </td>
          <td class="actions">
            <form id="proxy-<%= proxy.id %>" method="post" action="/proxies/<%= proxy.id %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="button small">Save</button>
            </form>
            <form method="post" action="/proxies/<%= proxy.id %>/delete" data-confirm="Delete this local proxy record?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="button small danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('partials/foot') %>
