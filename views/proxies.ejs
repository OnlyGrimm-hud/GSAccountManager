<%- include('partials/head') %>
<section class="metric-grid proxy-metrics">
  <% [['total','Total Proxies'],['working','Working'],['failed','Failed'],['unchecked','Unchecked'],['assigned','Assigned'],['unassigned','Unassigned']].forEach(item => { %>
    <article class="metric"><span><%= item[1] %></span><strong><%= counts[item[0]] || 0 %></strong></article>
  <% }) %>
</section>

<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Network Storage</p>
      <h2>Proxies</h2>
    </div>
    <div class="actions">
      <% if (!isLimitedAccess) { %>
        <button class="button" type="button" data-open-modal="proxy-import-modal">Import Proxies</button>
        <form method="post" action="/proxies/auto-assign">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="button">Auto assign HTTP proxies</button>
        </form>
      <% } %>
      <button class="button primary" type="button" data-open-modal="proxy-export-modal">Export Proxies</button>
    </div>
  </div>
  <% if (query && query.imported) { %><p class="notice">Imported <%= Number(query.imported || 0) %> proxy line(s). Invalid <%= Number(query.invalid || 0) %>.</p><% } %>
  <p class="muted">Default proxy type is HTTP. Proxy credentials stay encrypted and hidden in tables.</p>
  <% if (isLimitedAccess) { %><p class="notice">Private-build access is inactive. Proxy data remains locked until an admin activates access.</p><% } %>
</section>

<% if (!isLimitedAccess) { %>
<section class="content-grid">
  <form method="post" action="/proxies" class="panel form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2>Add Proxy</h2>
    <label>Type<select name="proxy_type"><% proxyTypes.forEach(t => { %><option value="<%= t %>" <%= t === 'HTTP' ? 'selected' : '' %>><%= t %></option><% }) %></select></label>
    <label>Name<input name="name" placeholder="US HTTP 1"></label>
    <label>Host<input name="host"></label>
    <label>Port<input name="port" type="number" min="1" max="65535"></label>
    <label>Username<input name="username" type="password"></label>
    <label>Password<input name="password" type="password"></label>
    <label>Category<input list="proxy-category-options-page" name="category"></label>
    <label>Country Code<input name="country_code" maxlength="2"></label>
    <label>Status<select name="status"><% proxyStatuses.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %></select></label>
    <label>Max Accounts Override<input name="max_accounts_per_proxy" type="number" min="1" placeholder="<%= settings.max_accounts_per_proxy || 5 %>"></label>
    <label>Notes<textarea name="notes"></textarea></label>
    <button class="button primary">Save proxy</button>
  </form>
  <article class="panel">
    <h2>Import / Export Proxies</h2>
    <p class="muted">Use the import modal for preview and confirmation before saving. Supported formats are host:port and host:port:username:password.</p>
    <div class="actions">
      <button class="button primary" type="button" data-open-modal="proxy-import-modal">Open Import Proxies</button>
      <button class="button" type="button" data-open-modal="proxy-export-modal">Export Proxies</button>
      <span class="tag">Proxy testing coming soon</span>
    </div>
  </article>
</section>
<% } %>

<datalist id="proxy-category-options-page"><% categories.forEach(category => { %><option value="<%= category %>"></option><% }) %></datalist>

<section class="panel">
  <div class="panel-head">
    <h2>Saved Proxies</h2>
    <span class="tag">Max <%= settings.max_accounts_per_proxy || 5 %> accounts per proxy</span>
  </div>
  <% if (!isLimitedAccess) { %>
    <div class="bulk-bar proxy-bulk-bar">
      <button class="button" form="proxy-export-form" formaction="/proxies/bulk-status" name="status" value="working">Mark Working</button>
      <button class="button" form="proxy-export-form" formaction="/proxies/bulk-status" name="status" value="failed">Mark Failed</button>
      <button class="button" form="proxy-export-form" formaction="/proxies/bulk-status" name="status" value="unchecked">Mark Unchecked</button>
      <span class="tag">Assign selected proxies from Accounts</span>
      <span class="tag">Proxy testing coming soon</span>
    </div>
  <% } %>
  <table>
    <thead><tr><th><input type="checkbox" data-select-all="[name='proxy_ids']"></th><th>Name</th><th>Host</th><th>Port</th><th>Type</th><th>Category</th><th>Country</th><th>Status</th><th>Assigned</th><th>Max</th><th>Notes</th><th>Credentials</th><th>Actions</th></tr></thead>
    <tbody>
      <% proxies.forEach(proxy => { %>
        <tr>
          <td><input form="proxy-export-form" type="checkbox" name="proxy_ids" value="<%= proxy.id %>"></td>
          <td><% if (isLimitedAccess) { %><%= proxy.name || '' %><% } else { %><input class="table-input" form="proxy-<%= proxy.id %>" name="name" value="<%= proxy.name || '' %>"><% } %></td>
          <td><% if (isLimitedAccess) { %><%= proxy.host %><% } else { %><input class="table-input" form="proxy-<%= proxy.id %>" name="host" value="<%= proxy.host %>" required><% } %></td>
          <td><% if (isLimitedAccess) { %><%= proxy.port %><% } else { %><input class="table-input short" form="proxy-<%= proxy.id %>" name="port" type="number" min="1" max="65535" value="<%= proxy.port %>" required><% } %></td>
          <td><% if (isLimitedAccess) { %><%= proxy.proxy_type %><% } else { %><select form="proxy-<%= proxy.id %>" name="proxy_type"><% proxyTypes.forEach(type => { %><option value="<%= type %>" <%= proxy.proxy_type === type ? 'selected' : '' %>><%= type %></option><% }) %></select><% } %></td>
          <td><% if (isLimitedAccess) { %><%= proxy.category || '' %><% } else { %><input class="table-input" form="proxy-<%= proxy.id %>" name="category" value="<%= proxy.category || '' %>"><% } %></td>
          <td><% if (isLimitedAccess) { %><%= proxy.country_code || '' %><% } else { %><input class="table-input short" form="proxy-<%= proxy.id %>" name="country_code" maxlength="2" value="<%= proxy.country_code || '' %>"><% } %></td>
          <td><% if (isLimitedAccess) { %><span class="status <%= proxy.status %>"><%= proxy.status %></span><% } else { %><select form="proxy-<%= proxy.id %>" name="status"><% proxyStatuses.forEach(status => { %><option value="<%= status %>" <%= proxy.status === status ? 'selected' : '' %>><%= status %></option><% }) %></select><% } %></td>
          <td><%= proxy.assigned_count %></td>
          <td><% if (isLimitedAccess) { %><%= proxy.max_accounts_per_proxy || settings.max_accounts_per_proxy || 5 %><% } else { %><input class="table-input short" form="proxy-<%= proxy.id %>" name="max_accounts_per_proxy" type="number" min="1" value="<%= proxy.max_accounts_per_proxy || '' %>" placeholder="<%= settings.max_accounts_per_proxy || 5 %>"><% } %></td>
          <td><% if (isLimitedAccess) { %><%= proxy.notes || '' %><% } else { %><input class="table-input" form="proxy-<%= proxy.id %>" name="notes" value="<%= proxy.notes || '' %>"><% } %></td>
          <td>
            <% if (isLimitedAccess) { %><span class="tag">Encrypted</span><% } else { %>
              <input class="table-input" form="proxy-<%= proxy.id %>" name="username" type="password" placeholder="new username">
              <input class="table-input" form="proxy-<%= proxy.id %>" name="password" type="password" placeholder="new password">
            <% } %>
          </td>
          <td class="actions">
            <% if (isLimitedAccess) { %>
              <span class="tag">Export only</span>
            <% } else { %>
              <form id="proxy-<%= proxy.id %>" method="post" action="/proxies/<%= proxy.id %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="button small">Save</button>
              </form>
              <form method="post" action="/proxies/<%= proxy.id %>/delete" data-confirm="Delete this local proxy record?">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="button small danger">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
      <% if (!proxies.length) { %><tr><td colspan="13"><p class="muted">Import proxies or add one manually.</p></td></tr><% } %>
    </tbody>
  </table>
</section>

<form id="proxy-export-form" method="post" action="/proxies/export">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
</form>

<% if (!isLimitedAccess) { %>
<div class="modal" id="proxy-import-modal" hidden>
  <div class="modal-panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Import</p>
        <h2>Import Proxies</h2>
      </div>
      <button class="icon-button" type="button" data-close-modal>Close</button>
    </div>
    <form id="proxy-import-form" method="post" action="/proxies/import" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="confirm_import" value="">
      <div class="form-grid three">
        <label>Proxy Type<select name="proxy_type"><option value="HTTP" selected>HTTP</option><option value="SOCKS5">SOCKS5</option></select></label>
        <label>Proxy Category<input list="proxy-category-options-page" name="category"></label>
        <label>Delimiter<input name="delimiter" value=":" maxlength="4" data-proxy-import-delimiter></label>
      </div>
      <div class="notice">
        <strong>Format examples</strong>
        <p class="muted">host:port | host:port:username:password</p>
      </div>
      <label>Pasted Proxies<textarea name="proxies_text" rows="10" placeholder="host:port" data-proxy-import-text></textarea></label>
      <div class="actions">
        <button class="button" type="button" data-preview-proxy-import>Preview parsed rows</button>
        <button class="button primary" disabled data-confirm-proxy-import>Import confirmed rows</button>
      </div>
      <div class="preview-box" data-proxy-import-preview></div>
    </form>
  </div>
</div>
<% } %>

<div class="modal" id="proxy-export-modal" hidden>
  <div class="modal-panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Export</p>
        <h2>Export Proxies</h2>
      </div>
      <button class="icon-button" type="button" data-close-modal>Close</button>
    </div>
    <div class="form-grid">
      <p class="notice">Proxy export can include sensitive proxy passwords only when explicitly selected.</p>
      <label>Delimiter<input form="proxy-export-form" name="delimiter" value=":"></label>
      <label class="check"><input form="proxy-export-form" type="checkbox" name="include_credentials" value="yes"> Include proxy usernames/passwords</label>
      <button class="button primary" form="proxy-export-form">Download TXT</button>
    </div>
  </div>
</div>
<%- include('partials/foot') %>
