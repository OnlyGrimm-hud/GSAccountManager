<%- include('partials/head') %>
<section class="content-grid">
  <form method="post" action="/settings" class="panel form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2>App Settings</h2>
    <label>App Name<input name="app_name" value="<%= settings.app_name || appName %>"></label>
    <label>Theme<input name="theme_name" value="<%= settings.theme_name || 'Premium Dark' %>"></label>
    <label>Default Account Type<select name="default_account_type"><% accountTypes.forEach(t => { %><option value="<%= t %>" <%= settings.default_account_type === t ? 'selected' : '' %>><%= t %></option><% }) %></select></label>
    <label>Default Proxy Type<select name="default_proxy_type"><% proxyTypes.forEach(t => { %><option value="<%= t %>" <%= settings.default_proxy_type === t ? 'selected' : '' %>><%= t %></option><% }) %></select></label>
    <label>Default Email Provider<input name="default_email_provider" value="<%= settings.default_email_provider || 'Outlook' %>"></label>
    <label>Password Length<input type="number" min="4" max="64" name="password_length" value="<%= settings.password_length || '9' %>"></label>
    <label>Max Accounts Per Proxy<input type="number" min="1" name="max_accounts_per_proxy" value="<%= settings.max_accounts_per_proxy || '5' %>"></label>
    <label>Preferred Export Format<select name="preferred_export_format">
      <% exportFormats.forEach(f => { %><option value="<%= f %>" <%= settings.preferred_export_format === f ? 'selected' : '' %>><%= f %></option><% }) %>
    </select></label>
    <label>Workflow Mode<select name="workflow_mode">
      <% workflowModes.forEach(mode => { %><option value="<%= mode %>" <%= settings.workflow_mode === mode ? 'selected' : '' %>><%= mode %></option><% }) %>
    </select></label>
    <label>Export Behavior Default<select name="export_behavior_default">
      <% ['keep','mark_exported','archive','delete'].forEach(f => { %><option value="<%= f %>" <%= settings.export_behavior_default === f ? 'selected' : '' %>><%= f %></option><% }) %>
    </select></label>
    <label>Mask Sensitive Values<select name="mask_sensitive_values"><option value="true" <%= settings.mask_sensitive_values === 'true' ? 'selected' : '' %>>true</option><option value="false" <%= settings.mask_sensitive_values === 'false' ? 'selected' : '' %>>false</option></select></label>
    <label>Dense Table Mode<select name="dense_table_mode"><option value="false" <%= settings.dense_table_mode !== 'true' ? 'selected' : '' %>>false</option><option value="true" <%= settings.dense_table_mode === 'true' ? 'selected' : '' %>>true</option></select></label>
    <label>OTP Refresh Interval<input type="number" min="15" max="60" name="otp_refresh_interval" value="<%= settings.otp_refresh_interval || '30' %>"></label>
    <label>Snapshot Interval Seconds<input type="number" min="15" max="300" name="screenshot_interval_seconds" value="<%= settings.screenshot_interval_seconds || '30' %>"></label>
    <p class="row-line"><span>App Version</span><strong>v<%= appVersion %></strong></p>
    <button class="button primary">Save settings</button>
  </form>
  <section class="panel form-grid">
    <h2>Manual Page URLs</h2>
    <form method="post" action="/settings" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% ['app_name','theme_name','default_account_type','default_proxy_type','default_email_provider','password_length','max_accounts_per_proxy','preferred_export_format','workflow_mode','export_behavior_default','mask_sensitive_values','otp_refresh_interval'].forEach(key => { %><input type="hidden" name="<%= key %>" value="<%= settings[key] || '' %>"><% }) %>
      <label>Email Signup URL<input name="email_signup_url" value="<%= settings.email_signup_url || 'https://signup.live.com/' %>"></label>
      <label>Email Sign-In URL<input name="email_signin_url" value="<%= settings.email_signin_url || 'https://outlook.live.com/' %>"></label>
      <label>Account Settings URL<input name="account_settings_url" value="<%= settings.account_settings_url || 'https://account.jagex.com/' %>"></label>
      <label>Upgrade URL<input name="upgrade_url" value="<%= settings.upgrade_url || 'https://account.jagex.com/' %>"></label>
      <button class="button">Save URLs</button>
    </form>
  </section>
</section>
<section class="panel form-grid">
  <h2>Subscription Placeholders</h2>
  <form method="post" action="/settings" class="form-grid three">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>LTC
      <select name="payment_method_ltc_enabled">
        <option value="false" <%= settings.payment_method_ltc_enabled !== 'true' ? 'selected' : '' %>>planned</option>
        <option value="true" <%= settings.payment_method_ltc_enabled === 'true' ? 'selected' : '' %>>enabled placeholder</option>
      </select>
    </label>
    <label>BTC
      <select name="payment_method_btc_enabled">
        <option value="false" <%= settings.payment_method_btc_enabled !== 'true' ? 'selected' : '' %>>planned</option>
        <option value="true" <%= settings.payment_method_btc_enabled === 'true' ? 'selected' : '' %>>enabled placeholder</option>
      </select>
    </label>
    <label>ETH
      <select name="payment_method_eth_enabled">
        <option value="false" <%= settings.payment_method_eth_enabled !== 'true' ? 'selected' : '' %>>planned</option>
        <option value="true" <%= settings.payment_method_eth_enabled === 'true' ? 'selected' : '' %>>enabled placeholder</option>
      </select>
    </label>
    <label>Manual Admin Activation
      <select name="manual_admin_activation_enabled">
        <option value="true" <%= settings.manual_admin_activation_enabled !== 'false' ? 'selected' : '' %>>enabled</option>
        <option value="false" <%= settings.manual_admin_activation_enabled === 'false' ? 'selected' : '' %>>disabled</option>
      </select>
    </label>
    <button class="button primary">Save subscription placeholders</button>
  </form>
</section>
<section class="panel form-grid">
  <h2>Companion</h2>
  <form method="post" action="/settings" class="form-grid three">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Require helper for proxied browser actions
      <select name="require_helper_for_proxy_actions">
        <option value="true" <%= settings.require_helper_for_proxy_actions !== 'false' ? 'selected' : '' %>>true</option>
        <option value="false" <%= settings.require_helper_for_proxy_actions === 'false' ? 'selected' : '' %>>false</option>
      </select>
    </label>
    <label>Allow website-only normal browser open
      <select name="allow_website_only_browser_open">
        <option value="true" <%= settings.allow_website_only_browser_open !== 'false' ? 'selected' : '' %>>true</option>
        <option value="false" <%= settings.allow_website_only_browser_open === 'false' ? 'selected' : '' %>>false</option>
      </select>
    </label>
    <label>Warn before opening without helper/proxy
      <select name="warn_before_opening_without_helper">
        <option value="true" <%= settings.warn_before_opening_without_helper !== 'false' ? 'selected' : '' %>>true</option>
        <option value="false" <%= settings.warn_before_opening_without_helper === 'false' ? 'selected' : '' %>>false</option>
      </select>
    </label>
    <label>Require confirmation before direct/no-proxy open
      <select name="require_confirmation_before_direct_open">
        <option value="true" <%= settings.require_confirmation_before_direct_open !== 'false' ? 'selected' : '' %>>true</option>
        <option value="false" <%= settings.require_confirmation_before_direct_open === 'false' ? 'selected' : '' %>>false</option>
      </select>
    </label>
    <label>Show proxy mode before opening page
      <select name="show_proxy_mode_before_open">
        <option value="true" <%= settings.show_proxy_mode_before_open !== 'false' ? 'selected' : '' %>>true</option>
        <option value="false" <%= settings.show_proxy_mode_before_open === 'false' ? 'selected' : '' %>>false</option>
      </select>
    </label>
    <label>Enable assisted fill buttons
      <select name="enable_assisted_fill_buttons">
        <option value="false" <%= settings.enable_assisted_fill_buttons !== 'true' ? 'selected' : '' %>>false</option>
        <option value="true" <%= settings.enable_assisted_fill_buttons === 'true' ? 'selected' : '' %>>true</option>
      </select>
    </label>
    <button class="button primary">Save helper settings</button>
  </form>
</section>
<section class="panel">
  <h2>Render Checklist</h2>
  <p class="row-line"><span>Root Directory</span><strong>blank / repository root</strong></p>
  <p class="row-line"><span>Build Command</span><strong>npm install</strong></p>
  <p class="row-line"><span>Start Command</span><strong>npm start</strong></p>
  <p class="row-line"><span>Health Check Path</span><strong>/healthz</strong></p>
  <p class="row-line"><span>DATABASE_URL</span><strong>required</strong></p>
  <p class="row-line"><span>ENCRYPTION_KEY</span><strong>32 decoded bytes</strong></p>
  <p class="row-line"><span>SESSION_SECRET</span><strong>required</strong></p>
  <p class="row-line"><span>AUTH_MODE</span><strong>discord</strong></p>
  <p class="row-line"><span>APP_BASE_URL</span><strong>required</strong></p>
  <p class="row-line"><span>Discord OAuth</span><strong>required</strong></p>
  <p class="row-line"><span>Admin fallback</span><strong>hidden in Discord mode</strong></p>
  <p class="row-line"><span>App Version</span><strong>v<%= appVersion %></strong></p>
</section>
<section class="panel">
  <h2>Production Checklist</h2>
  <div class="checklist-grid">
    <p class="row-line"><span>PostgreSQL connected</span><strong class="status ready">ready</strong></p>
    <p class="row-line"><span>Encryption key loaded</span><strong class="status ready">ready</strong></p>
    <p class="row-line"><span>Discord auth enabled</span><strong class="status ready">ready</strong></p>
    <p class="row-line"><span>Secure cookies enabled in production</span><strong class="status ready">ready</strong></p>
    <p class="row-line"><span>Health check available</span><strong class="status ready">ready</strong></p>
    <p class="row-line"><span>Import/export available</span><strong class="status ready">ready</strong></p>
    <p class="row-line"><span>Logs available</span><strong class="status ready">ready</strong></p>
  </div>
</section>
<%- include('partials/foot') %>
